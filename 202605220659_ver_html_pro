/* ============ 月次データ統合（最大31件） ============ */
var HUB_MAX_DAYS=31;
var hubText=""; // 統合済みのメモ本文（複数ソースを連結）

// 連続して同じ日付が並ぶ重複を除去（同日複数タスクで日付が増殖しないように）
function hubDedupDates(text){
  var dedup=[], prevDate=null;
  (text||"").split("\n").forEach(function(ln){
    var t=ln.trim();
    var isDate = /^\d{4}\D+\d{1,2}\D+\d{1,2}/.test(t) && t.replace(/[\d\/\-\.年月日（）\(\)月火水木金土曜\s]/g,"").length<=2;
    if(isDate){ if(t===prevDate) return; prevDate=t; }
    dedup.push(ln);
  });
  return dedup.join("\n");
}

// 列ヘッダ名から「日付/タスク/時間/タグ」の列番号を推定（Notion/Excelの表記ゆれ対応）
function hubDetectColumns(header){
  var ci={ date:-1, task:-1, min:-1, tag:-1 };
  header.forEach(function(raw,i){
    var h=(raw||"").trim().toLowerCase();
    if(!h) return;
    // 日付
    if(ci.date<0 && /(日付|日時|実施日|作業日|年月日|^date$|date|day)/.test(h)) ci.date=i;
    // タスク名（Notionのタイトル列＝「名前/Name」も拾う）
    if(ci.task<0 && /(タスク|作業内容|作業|内容|項目|やったこと|予定|実績|名前|名称|タイトル|title|name|task|todo|item)/.test(h)) ci.task=i;
    // 時間・工数
    if(ci.min<0 && /(時間|工数|所要|分|duration|time|hours?|min)/.test(h)) ci.min=i;
    // タグ・分類
    if(ci.tag<0 && /(タグ|ラベル|分類|カテゴリ|カテゴリー|区分|種別|tag|label|category|type)/.test(h)) ci.tag=i;
  });
  return ci;
}
// タグ文字列を個別タグに分割（Notionのマルチセレクトはカンマ/読点/空白区切り）
function hubSplitTags(s){
  if(!s) return [];
  return s.split(/[,、，;；\s]+/).map(function(x){ return x.replace(/^[#＃]/,"").trim(); }).filter(Boolean);
}
// 時間セルを「90分」のような表記へ正規化（数値だけなら分とみなす）
function hubNormTime(s){
  s=(s||"").trim(); if(!s) return "";
  if(/^\d+(\.\d+)?$/.test(s)) return s+"分";      // 90 → 90分
  return s;                                        // 90分 / 1h / 1:30 はそのまま
}

// Markdownテーブル/箇条書き/CSVを「メモ行」テキストに正規化
function hubNormalizeToMemo(raw, kind){
  if(!raw) return "";
  raw=raw.replace(/^\uFEFF/,"");
  var out=[];
  if(kind==="csv"){
    var rows=_parseCsv(raw);
    if(!rows.length) return "";
    var header=rows[0].map(function(s){return (s||"").trim();});
    var ci=hubDetectColumns(header);
    var hasHeader = (ci.task>=0 || ci.date>=0 || ci.min>=0 || ci.tag>=0);
    var body = hasHeader ? rows.slice(1) : rows;
    body.forEach(function(r){
      if(hasHeader && ci.task>=0){
        var dt=ci.date>=0?(r[ci.date]||"").trim():"";
        var tk=(r[ci.task]||"").trim(); if(!tk) return;
        var mn=ci.min>=0?hubNormTime(r[ci.min]):"";
        var tags=ci.tag>=0?hubSplitTags(r[ci.tag]):[];
        if(dt) out.push(dt);
        var line="・"+tk;
        if(mn) line+=" "+mn;
        if(tags.length) line+=" "+tags.map(function(t){return "#"+t;}).join(" ");
        out.push(line);
      } else {
        out.push(r.join(" ").trim()); // ヘッダ無し：行全体を1メモ行に
      }
    });
    return hubDedupDates(out.join("\n"));
  }
  // Markdown / テキスト
  var mdLines=raw.split(/\r?\n/);
  // まずMarkdownテーブルのまとまりを検出してCSV的に処理
  var tableRows=[], inTable=false;
  // Notionプロパティ（縦並びのキー:値）を1レコードに合成
  var propRec={has:false, date:"", task:"", min:"", tags:[]};
  function flushProp(){
    if(propRec.has && propRec.task){
      if(propRec.date) out.push(propRec.date);
      var line="・"+propRec.task;
      if(propRec.min) line+=" "+propRec.min;
      if(propRec.tags.length) line+=" "+propRec.tags.map(function(t){return "#"+t;}).join(" ");
      out.push(line);
    }
    propRec={has:false, date:"", task:"", min:"", tags:[]};
  }
  function flushTable(){
    if(tableRows.length){
      // 区切り線を除去
      var clean=tableRows.filter(function(cells){ return !cells.every(function(c){return /^:?-+:?$/.test(c)||c===""; }); });
      if(clean.length){
        // CSV正規化に委譲（ヘッダ認識・タグ分割・時間正規化が効く）
        var csvText=clean.map(function(cells){ return cells.map(function(c){ return /[",\n]/.test(c)?('"'+c.replace(/"/g,'""')+'"'):c; }).join(","); }).join("\n");
        var memoFromTable=hubNormalizeToMemo(csvText,"csv");
        if(memoFromTable) out.push(memoFromTable);
      }
      tableRows=[];
    }
    inTable=false;
  }
  mdLines.forEach(function(line){
    line=line.replace(/\s+$/,"");
    if(/^\s*\|.*\|\s*$/.test(line)){
      inTable=true;
      tableRows.push(line.split("|").slice(1,-1).map(function(s){return s.trim();}));
      return;
    } else if(inTable){ flushTable(); }
    if(!line.trim()){ flushProp(); return; }
    // Notionプロパティ行（キー: 値）→ レコードに溜める
    var prop=/^[-*]?\s*([^：:]{1,16})\s*[:：]\s*(.+)$/.exec(line);
    if(prop){
      var key=prop[1].trim(), val=prop[2].trim();
      if(/(日付|日時|date)/i.test(key)){ propRec.date=val; }
      else if(/(タグ|ラベル|分類|カテゴリ|区分|tag)/i.test(key)){ propRec.tags=propRec.tags.concat(hubSplitTags(val)); }
      else if(/(時間|工数|所要|分|duration|time)/i.test(key)){ propRec.min=hubNormTime(val); }
      else if(/(名前|名称|タイトル|タスク|作業|内容|項目|title|name|task)/i.test(key)){ propRec.task=val; }
      else { if(!propRec.task) propRec.task=val; } // 最初の不明プロパティをタスク名候補に
      propRec.has=true;
      return;
    }
    // プロパティ以外の通常行が来たら、溜まったレコードを確定
    flushProp();
    var h=/^#{1,6}\s*(.+)$/.exec(line);
    if(h){ out.push(h[1].trim()); return; }
    out.push(line);
  });
  flushProp();
  flushTable();
  return hubDedupDates(out.join("\n"));
}

