var LANG_KEY="usausa_lang_v1";
var currentLang="jp";
// 翻訳対象セレクタ（UI要素）
var I18N_SEL="header.hero h1, header.hero p, .tab, h2, h3, label, button, option, p.hint, .bk-title, .tt-head>div, .tpl-chip";
// 元の日本語を保持してから英訳。日本語に戻すときは原文へ。
// 重要：子要素を持つ要素（例：<label><input>…</label>）は textContent 書換で
// 子（チェックボックス等）が消えるため対象外にする。テキストのみの要素だけ翻訳する。
function i18nTranslatable(el){
  // 子要素を含む場合は除外（テキストノードのみ＝childElementCount===0）
  return el.childElementCount===0;
}
// 子要素を持つ要素（例：<label><input>テキスト</label>）の直下テキストノードだけを翻訳。
// 子要素（checkbox等）は一切触らないので消えない。
function i18nTranslateChildText(el, lang){
  [].slice.call(el.childNodes).forEach(function(node){
    if(node.nodeType!==3) return; // テキストノードのみ
    var raw=node.nodeValue;
    var key=(raw||"").trim();
    if(!key) return;
    // 原文保存（ノードに属性は付けられないので、要素にまとめて保存）
    var store=el.getAttribute("data-jp-textnodes");
    if(store==null){ // 初回スナップショット
      // 各テキストノードの原文を順序付きで保存
      var arr=[].slice.call(el.childNodes).filter(function(n){return n.nodeType===3;}).map(function(n){return n.nodeValue;});
      el.setAttribute("data-jp-textnodes", JSON.stringify(arr));
    }
    if(lang==="en"){
      var en=(typeof UI_DICT!=="undefined" && UI_DICT[key]!=null) ? UI_DICT[key] : null;
      if(en!=null){ node.nodeValue=raw.replace(key,en); }
    } else {
      // 日本語へ戻す：保存した原文から対応するノードを復元
      try{
        var saved=JSON.parse(el.getAttribute("data-jp-textnodes")||"[]");
        var textNodes=[].slice.call(el.childNodes).filter(function(n){return n.nodeType===3;});
        var idx=textNodes.indexOf(node);
        if(idx>=0 && saved[idx]!=null){ node.nodeValue=saved[idx]; }
      }catch(e){}
    }
  });
}
function i18nSnapshot(){
  [].slice.call(document.querySelectorAll(I18N_SEL)).forEach(function(el){
    if(!i18nTranslatable(el)) return;
    if(el.getAttribute("data-jp")==null){ el.setAttribute("data-jp", el.textContent); }
  });
}
function applyLangText(lang){
  i18nSnapshot();
  [].slice.call(document.querySelectorAll(I18N_SEL)).forEach(function(el){
    // 子要素を持つ要素（checkbox入りlabel等）は、末尾テキストノードだけ翻訳して子は保護
    if(!i18nTranslatable(el)){
      i18nTranslateChildText(el, lang);
      return;
    }
    var jp=el.getAttribute("data-jp"); if(jp==null) return;
    var key=jp.trim();
    if(lang==="en"){
      var en=(typeof UI_DICT!=="undefined" && UI_DICT[key]!=null) ? UI_DICT[key] : null;
      if(en!=null){
        // 元テキストの前後空白を保ったまま中身を差し替え
        el.textContent = jp.replace(key, en);
      }
    } else {
      el.textContent = jp; // 原文（日本語）へ戻す
    }
  });
  // ヘッダのtitle/subtitleはI18Nで明示上書き（data-i18n優先）
  var dict=I18N[lang]||I18N.jp;
  [].slice.call(document.querySelectorAll("[data-i18n]")).forEach(function(el){
    var k=el.getAttribute("data-i18n"); if(dict[k]!=null) el.textContent=dict[k];
  });
}
function setLang(lang){
  if(lang!=="jp" && lang!=="en") lang="jp";
  currentLang=lang;
  document.body.classList.remove("theme-jp","theme-uk");
  document.body.classList.add(lang==="en" ? "theme-uk" : "theme-jp");
  applyLangText(lang);
  var jp=document.getElementById("langJp"), en=document.getElementById("langEn");
  if(jp&&en){ jp.classList.toggle("active", lang==="jp"); en.classList.toggle("active", lang==="en"); }
  document.documentElement.lang = (lang==="en"?"en":"ja");
  if(lsAvailable()){ try{ window.localStorage.setItem(LANG_KEY, lang); }catch(e){} }
}
function initLang(){
  var saved="jp";
  if(lsAvailable()){ try{ saved=window.localStorage.getItem(LANG_KEY)||"jp"; }catch(e){} }
  setLang(saved);
}
// 動的に要素を足したあと、現在の言語を再適用する（英語なら新規要素も英訳）
function i18nRefresh(){ if(currentLang==="en"){ applyLangText("en"); } }

