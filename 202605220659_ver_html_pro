// 保存ログからCheck/Actを下書き
function pdcaDraftFromLog(){
  var days=loadDays();
  if(!days.length){ toast("保存ログがありません（時間割タブで保存）"); return; }
  days=days.slice().sort(function(a,b){return (dateKey(a.date)||0)-(dateKey(b.date)||0);});
  var recent=days.slice(-7);
  var probs=[], tries=[], rateSum=0;
  recent.forEach(function(d){
    rateSum+=d.rate||0;
    if(d.problem) probs.push(d.problem);
    if(d.tryv) tries.push(d.tryv);
    (d.periods||[]).forEach(function(p){ if(!(p.kind==="break"||p.isBreak) && p.status==="△"){ var w=(p.actual||p.plan||"").trim(); if(w) probs.push(w+"（未達）"); } });
  });
  function uniq(a){ var s={},o=[]; a.forEach(function(x){ if(!s[x]){s[x]=1;o.push(x);} }); return o; }
  probs=uniq(probs); tries=uniq(tries);
  var avg=recent.length?Math.round(rateSum/recent.length):0;
  if(!v("pd_check")){
    document.getElementById("pd_check").value="直近"+recent.length+"日の平均達成率 "+avg+"%\n"+(probs.length?("課題：\n- "+probs.join("\n- ")):"課題：特記なし");
  }
  if(!v("pd_act") && tries.length){
