// 日付文字列を比較可能なキーに（"2026/05/01" や "2026/5/1（水）" を 20260501 に）
function dateKey(s){
  var m=/(\d{4})\D+(\d{1,2})\D+(\d{1,2})/.exec(s||"");
  if(!m) return null;
  return parseInt(m[1],10)*10000+parseInt(m[2],10)*100+parseInt(m[3],10);
}
function daysInRange(from, to){
  var fk=dateKey(from), tk=dateKey(to);
  return loadDays().filter(function(d){
    var k=dateKey(d.date); if(k==null) return (!fk&&!tk); // 日付不明は無期間時のみ含める
    if(fk && k<fk) return false;
    if(tk && k>tk) return false;
    return true;
  });
}
