    local.set(lh,0); local.set(nameB,lh.length); local.set(f.data,lh.length+nameB.length);
    locals.push(local);
    var ch=[].concat(_u32(0x02014b50),_u16(20),_u16(20),_u16(0),_u16(0),_u16(0),_u16(0),_u32(crc),_u32(size),_u32(size),_u16(nameB.length),_u16(0),_u16(0),_u16(0),_u16(0),_u32(0),_u32(offset));
    var cent=new Uint8Array(ch.length+nameB.length); cent.set(ch,0); cent.set(nameB,ch.length);
