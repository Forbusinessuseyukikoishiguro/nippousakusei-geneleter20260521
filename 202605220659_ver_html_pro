function toMin(t){
  var m=/^(\d{1,2}):(\d{2})$/.exec((t||"").trim());
  if(!m) return null;
  return parseInt(m[1],10)*60+parseInt(m[2],10);
}
// ===== 丸め設定（画面で選択） =====
var ROUND_UNIT = 15;        // 15 / 30 / 60（分）
var ROUND_MODE = "round";   // "round"=四捨五入 / "ceil"=切り上げ
function applyRound(min){
  if(min==null) return null;
  var u=ROUND_UNIT||15;
  return (ROUND_MODE==="ceil" ? Math.ceil(min/u) : Math.round(min/u)) * u;
}
// 後方互換：旧名 round15 は現在の設定で丸める
function round15(min){ return applyRound(min); }
function unitLabel(){ return ROUND_UNIT===60 ? "1時間単位" : (ROUND_UNIT+"分単位"); }
function modeLabel(){ return ROUND_MODE==="ceil" ? "切り上げ" : "四捨五入"; }
// 丸め設定の変更を反映して再計算
function onRoundChange(){
  var u=document.getElementById("round_unit"), m=document.getElementById("round_mode");
  if(u) ROUND_UNIT=parseInt(u.value,10)||15;
  if(m) ROUND_MODE=(m.value==="ceil"?"ceil":"round");
  recalcTT();
}

