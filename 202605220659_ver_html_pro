/* ============ 一人MTG（PDCA）タイマー ============ */
var PDCA_PHASES=[
  {key:"P", name:"📝 Plan（計画）", min:"pd_min_P", sub:"目標とやることを書き出す"},
  {key:"D", name:"🏃 Do（実行）",  min:"pd_min_D", sub:"手を動かす・進める"},
  {key:"C", name:"🔍 Check（評価）",min:"pd_min_C", sub:"結果をふりかえる"},
  {key:"A", name:"🚀 Act（改善）",  min:"pd_min_A", sub:"次の一手を決める"}
];
var pdca={timer:null, idx:-1, remain:0, total:0, running:false, mode:null};

function pdcaFmt(sec){ var m=Math.floor(sec/60), s=sec%60; return ("0"+m).slice(-2)+":"+("0"+s).slice(-2); }
function pdcaSetClock(){
  document.getElementById("pd_clock").textContent=pdcaFmt(Math.max(0,pdca.remain));
  var fill=document.getElementById("pd_barfill");
  fill.style.width = pdca.total>0 ? (Math.max(0,pdca.remain)/pdca.total*100)+"%" : "0%";
}
function pdcaHighlight(phaseKey){
  [].slice.call(document.querySelectorAll(".pdca-step")).forEach(function(el){
    el.classList.toggle("active", el.dataset.phase===phaseKey);
  });
}
function pdcaBeep(){
  if(!document.getElementById("pd_sound") || !document.getElementById("pd_sound").checked) return;
  try{
    var Ctx=window.AudioContext||window.webkitAudioContext; if(!Ctx) return;
    var ctx=new Ctx(); var osc=ctx.createOscillator(); var g=ctx.createGain();
    osc.connect(g); g.connect(ctx.destination);
    osc.type="sine"; osc.frequency.value=880; g.gain.value=0.15;
    osc.start(); setTimeout(function(){ osc.stop(); ctx.close&&ctx.close(); }, 350);
  }catch(e){}
}
function pdcaTick(){
  pdca.remain--;
  pdcaSetClock();
  if(pdca.remain<=0){
    pdcaBeep();
    if(pdca.mode==="auto"){
      // 次のステップへ
      pdcaGoto(pdca.idx+1);
    } else {
      pdcaStopTimer();
      document.getElementById("pd_phase").textContent="⏰ 終了";
      document.getElementById("pd_sub").textContent="おつかれさま🐰";
      document.getElementById("pdcaTimer").classList.remove("running");
    }
  }
}
function pdcaStopTimer(){
  if(pdca.timer){ clearInterval(pdca.timer); pdca.timer=null; }
  pdca.running=false;
}
function pdcaStartTimer(){
  pdcaStopTimer();
  pdca.running=true;
  document.getElementById("pdcaTimer").classList.add("running");
  pdca.timer=setInterval(pdcaTick,1000);
}
function pdcaPhaseMinutes(i){
  var ph=PDCA_PHASES[i]; var el=document.getElementById(ph.min);
  var mn=parseInt(el&&el.value,10); if(isNaN(mn)||mn<1) mn=1;
  return mn;
}
function pdcaGoto(i){
  if(i>=PDCA_PHASES.length){
    pdcaStopTimer();
    document.getElementById("pd_phase").textContent="🎉 MTG完了";
    document.getElementById("pd_clock").textContent="00:00";
    document.getElementById("pd_sub").textContent="PDCAを1周しました。お疲れさまでした🐰";
    document.getElementById("pdcaTimer").classList.remove("running");
    pdcaHighlight(null);
    pdca.idx=-1; pdca.mode=null;
    toast("PDCA 1周 完了！");
    return;
  }
  pdca.idx=i; pdca.mode="auto";
  var ph=PDCA_PHASES[i];
  pdca.total=pdcaPhaseMinutes(i)*60; pdca.remain=pdca.total;
  document.getElementById("pd_phase").textContent=ph.name;
  document.getElementById("pd_sub").textContent=ph.sub+"（残り "+pdcaPhaseMinutes(i)+"分）";
  pdcaHighlight(ph.key);
  pdcaSetClock();
  pdcaStartTimer();
}
function pdcaStart(){
  // 一時停止からの再開か、最初から開始か
  if(!pdca.running && pdca.idx>=0 && pdca.remain>0){ pdcaStartTimer(); return; }
  pdcaGoto(0);
}
function pdcaPause(){
  if(pdca.running){ pdcaStopTimer(); document.getElementById("pdcaTimer").classList.remove("running");
    document.getElementById("pd_sub").textContent="一時停止中（▶で再開）"; }
}
function pdcaSkip(){
  if(pdca.mode==="auto" && pdca.idx>=0){ pdcaGoto(pdca.idx+1); }
  else { toast("自動MTG中のみ次へ進めます"); }
}
function pdcaReset(){
  pdcaStopTimer();
