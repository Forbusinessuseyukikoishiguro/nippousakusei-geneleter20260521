<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>うさうさ 日報作成ジェネレーター 🐰</title>
<style>
  :root{
    --cream:#fffaf2; --cream2:#fdf3e3; --paper:#fff; --orange:#ea7d2b; --orange-deep:#cf6315;
    --gold:#c79a2e; --gold-soft:#e7c873; --ink:#3a2c20; --ink-soft:#6b5848;
    --line:#ecd9bd; --line-soft:#f3e6cf; --ok:#3f8f5f; --shadow:0 10px 30px rgba(180,120,40,.10);
    --bg1:#ffe9c8; --bg1a:rgba(255,233,200,0); --bg2:#ffeede; --bg2a:rgba(255,238,222,0);
    --accent:var(--orange); --accent-deep:var(--orange-deep);
    --headfont:"Hiragino Sans","Hiragino Kaku Gothic ProN","Yu Gothic","Meiryo",sans-serif;
  }
  /* テーマ：日本語＝緑ベース（オフホワイト×フォレストグリーン） */
  body.theme-jp{
    --cream:#f6faf5; --cream2:#eef5ec; --paper:#fffefb; --orange:#3f8f5f; --orange-deep:#2c6a45;
    --gold:#6fae7e; --gold-soft:#bfe0c7; --ink:#26352b; --ink-soft:#5a6f60;
    --line:#d8e7da; --line-soft:#e8f1e8; --ok:#3f8f5f; --shadow:0 10px 30px rgba(60,140,90,.12);
    --bg1:#dff0e2; --bg1a:rgba(223,240,226,0); --bg2:#e9f3e6; --bg2a:rgba(233,243,230,0);
    --accent:#3f8f5f; --accent-deep:#2c6a45;
    --headfont:"Hiragino Sans","Hiragino Kaku Gothic ProN","Yu Gothic","Meiryo",sans-serif;
  }
  /* テーマ：英語＝カナダ風（メープルレッド×ホワイト、クリーンなサンセリフ見出し） */
  body.theme-uk{
    --cream:#fbf6f5; --cream2:#f4eceb; --paper:#ffffff; --orange:#d52b1e; --orange-deep:#a81d13;
    --gold:#e07a70; --gold-soft:#f3c9c4; --ink:#2b2b2d; --ink-soft:#6a5d5d;
    --line:#eed7d4; --line-soft:#f6e8e6; --ok:#3f8f5f; --shadow:0 10px 30px rgba(213,43,30,.12);
    --bg1:#fbe2df; --bg1a:rgba(251,226,223,0); --bg2:#f6eae8; --bg2a:rgba(246,234,232,0);
    --accent:#d52b1e; --accent-deep:#a81d13;
    --headfont:"Helvetica Neue",Helvetica,Arial,"Segoe UI",sans-serif;
  }
  body.theme-uk h1, body.theme-uk h2, body.theme-uk header.hero h1{font-family:var(--headfont);letter-spacing:.2px;}
  .lang-switch{position:absolute;top:14px;right:16px;display:flex;gap:6px;z-index:2;}
  /* ヘッダーのワンポイント（テーマ連動：日本=トウモロコシ／英=メープル） */
  .hero-motif{position:absolute;top:14px;left:16px;width:36px;height:48px;opacity:.92;z-index:2;}
  .hero-motif svg{width:100%;height:100%;display:none;filter:drop-shadow(0 2px 4px rgba(0,0,0,.08));}
  body.theme-jp .hero-motif .motif-corn{display:block;}
  body.theme-uk .hero-motif .motif-maple{display:block;}
  @media (max-width:520px){ .hero-motif{width:28px;height:38px;top:12px;left:12px;} }
  .lang-btn{border:1px solid var(--line);background:var(--paper);color:var(--ink-soft);border-radius:999px;
    padding:5px 12px;cursor:pointer;font-weight:700;font-size:.78rem;}
  .lang-btn.active{background:linear-gradient(135deg,var(--accent),var(--gold));color:#fff;border-color:transparent;}
  header.hero{position:relative;}
  /* 🐰 は言語ボタンの下・右寄せに置き、タイトル文字と重ならないようにする */
  .bunny{position:absolute;top:50px;right:24px;font-size:30px;filter:drop-shadow(0 4px 8px rgba(120,160,120,.25));z-index:1;}
  @media (max-width:520px){ .bunny{top:46px;right:14px;font-size:26px;} }
  
  body{margin:0;font-family:"Hiragino Sans","Hiragino Kaku Gothic ProN","Yu Gothic","Meiryo",sans-serif;
    color:var(--ink);line-height:1.7;-webkit-font-smoothing:antialiased;
    background:radial-gradient(900px 500px at 110% -10%, var(--bg1) 0%, var(--bg1a) 55%),
      radial-gradient(800px 600px at -10% 10%, var(--bg2) 0%, var(--bg2a) 50%),
      linear-gradient(180deg,var(--cream) 0%,var(--cream2) 100%);}
  .wrap{max-width:880px;margin:0 auto;padding:0 18px 80px;}

  header.hero{margin-top:32px;background:var(--paper);border:1px solid var(--line);border-radius:22px;
    padding:26px 30px;box-shadow:var(--shadow);position:relative;overflow:hidden;}
  header.hero::before{content:"";position:absolute;inset:0 0 auto 0;height:6px;
    background:linear-gradient(90deg,var(--gold-soft),var(--orange),var(--gold));}
  /* タイトル群はmotif(左)と🐰(右)に重ならないよう余白を確保 */
  header.hero h1{margin:0 0 6px;font-size:1.4rem;font-weight:800;padding-left:52px;padding-right:46px;min-height:34px;}
  header.hero p{margin:0;color:var(--ink-soft);font-size:.92rem;padding-right:46px;}
  @media (max-width:520px){
    header.hero h1{padding-left:40px;padding-right:40px;padding-top:34px;}
    header.hero p{padding-right:34px;}
    .hero-motif{top:40px;}
    .bunny{top:74px;}
  }

  .tabs{display:flex;gap:8px;margin:18px 0;flex-wrap:wrap;}
  .tab{flex:1 1 auto;min-width:150px;text-align:center;cursor:pointer;border:1px solid var(--line);
    background:var(--paper);padding:11px 14px;border-radius:14px;font-weight:700;color:var(--ink-soft);
    box-shadow:var(--shadow);transition:.15s;}
  .tab:hover{transform:translateY(-1px);}
  .tab.active{color:#fff;border-color:transparent;background:linear-gradient(135deg,var(--orange),var(--gold));}

  .panel{display:none;background:var(--paper);border:1px solid var(--line);border-radius:20px;
    padding:24px 26px;box-shadow:var(--shadow);}
  .panel.active{display:block;animation:rise .4s ease both;}
  @keyframes rise{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

  h2{font-size:1.05rem;font-weight:800;margin:4px 0 14px;padding-left:14px;position:relative;}
  h2::before{content:"";position:absolute;left:0;top:.18em;bottom:.18em;width:6px;border-radius:6px;
    background:linear-gradient(180deg,var(--orange),var(--gold));}
  h3{font-size:.92rem;font-weight:800;color:var(--orange-deep);margin:20px 0 8px;}
  .hint{font-size:.8rem;color:var(--ink-soft);margin:-2px 0 8px;}

  label{display:block;font-size:.82rem;font-weight:700;color:var(--ink-soft);margin:12px 0 4px;}
  input,select,textarea{width:100%;font:inherit;color:var(--ink);background:#fffdf9;
    border:1px solid var(--line);border-radius:10px;padding:9px 11px;outline:none;}
  input:focus,select:focus,textarea:focus{border-color:var(--orange);box-shadow:0 0 0 3px #ffe6c9;}
  textarea{resize:vertical;min-height:62px;line-height:1.6;}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:0 16px;}
  .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0 14px;}

  .task-row{display:grid;grid-template-columns:1.3fr .8fr 1.6fr 1.1fr auto;gap:8px;margin:8px 0;align-items:center;}
  .task-row input,.task-row select{margin:0;}
  .del{background:#fff1e6;border:1px solid #ffd6ad;color:var(--orange-deep);border-radius:9px;
    width:34px;height:34px;cursor:pointer;font-size:1rem;line-height:1;}
  .addbtn{margin-top:8px;background:#fff3e3;border:1px dashed var(--orange);color:var(--orange-deep);
    border-radius:10px;padding:8px 14px;cursor:pointer;font-weight:700;}

  .checks label{display:flex;align-items:center;gap:8px;font-weight:500;color:var(--ink);margin:6px 0;cursor:pointer;}
  .checks input{width:auto;}

  .toggle{display:flex;align-items:center;gap:8px;margin:14px 0 2px;font-weight:700;color:var(--ink-soft);cursor:pointer;}
  .toggle input{width:auto;}
  .collapsible{display:none;}
  .collapsible.open{display:block;}

  .gen{margin-top:22px;width:100%;background:linear-gradient(135deg,var(--orange),var(--orange-deep));
    color:#fff;border:none;border-radius:14px;padding:14px;font-size:1rem;font-weight:800;cursor:pointer;
    box-shadow:0 8px 20px rgba(207,99,21,.3);}
  .gen:hover{filter:brightness(1.04);}

  .outwrap{margin-top:22px;background:var(--paper);border:1px solid var(--line);border-radius:20px;
    padding:20px 22px;box-shadow:var(--shadow);}
  .outhead{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px;}
  .outhead h2{margin:0;}
  .outbtns{display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-end;}
  .outbtns button{border:1px solid var(--line);background:#fff7ee;color:var(--ink);border-radius:10px;
    padding:8px 14px;cursor:pointer;font-weight:700;}
  .outbtns button:hover{background:#ffeede;}
  #output{width:100%;min-height:320px;font-family:"SFMono-Regular",Consolas,Menlo,monospace;
    font-size:.86rem;line-height:1.65;background:#fffdf8;border:1px solid var(--line);border-radius:12px;padding:14px;}

  .toast{position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:#fff;padding:10px 20px;border-radius:999px;font-weight:700;font-size:.9rem;
    opacity:0;pointer-events:none;transition:.25s;z-index:50;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  .foot{text-align:center;color:var(--gold);font-weight:700;font-size:.8rem;letter-spacing:.06em;margin-top:24px;}

  /* ---- 時間割（HR学校風） ---- */
  .hr-card{background:linear-gradient(160deg,#fff6e9,#fff);border:1px solid var(--line);
    border-radius:14px;padding:14px 16px;margin:10px 0 16px;}
  .hr-card h3{margin:0 0 8px;}
  .tt-head,.tt-row{display:grid;
    grid-template-columns:60px 66px 64px 54px 54px 1.1fr 1.1fr 64px 34px 50px 28px 28px;gap:5px;align-items:center;}
  .tt-head{font-size:.72rem;font-weight:700;color:var(--ink-soft);padding:0 2px 4px;}
  .tt-row{margin:5px 0;border-left:6px solid transparent;padding-left:6px;border-radius:6px;transition:.2s;}
  .tt-row input,.tt-row select{margin:0;padding:7px 8px;font-size:.86rem;}
  .tt-row .tt-custom{padding:6px;font-size:.8rem;}
  .tt-row.brk{opacity:.85;}
  .tt-row.brk input[disabled]{background:#f6efe2;color:var(--ink-soft);}
  /* 区分カラー（左帯＋淡い背景） */
  .tt-row.kind-lesson{border-left-color:#e0792b;background:#fff5ea;}   /* 授業 */
  .tt-row.kind-meeting{border-left-color:#3f7fae;background:#eef6fb;}  /* 会議 */
  .tt-row.kind-work{border-left-color:#3f8f5f;background:#eef8f1;}     /* 作業 */
  .tt-row.kind-break{border-left-color:#b8a26a;background:#faf6ec;}    /* 休憩 */
  .tt-row.kind-other{border-left-color:#8a6fae;background:#f4f0fa;}    /* その他 */
  /* 差し込み（割込）コマ */
  .tt-row.insert{box-shadow:inset 3px 0 0 #d8492b, 0 0 0 1px #f3b8a6;}
  .tt-row.insert::before{content:"⚡";position:absolute;}
  .tt-ins{display:flex;align-items:center;justify-content:center;gap:2px;font-size:.72rem;color:var(--ink-soft);cursor:pointer;}
  .tt-ins input{width:auto;margin:0;}
  .ins-btn{border:1px solid var(--gold-soft);background:#fff3e2;color:var(--orange-deep);border-radius:8px;
    cursor:pointer;font-weight:800;font-size:.9rem;line-height:1;padding:0;}
  .ins-btn:hover{background:#ffe6c9;}

  /* 月次データ統合：ソース別取り込み */
  .hub-src{display:flex;flex-direction:column;gap:8px;margin:8px 0;}
  .hub-src-row{display:flex;flex-wrap:wrap;gap:6px;align-items:center;}
  .hub-src-label{flex:0 0 auto;font-weight:800;color:var(--orange-deep);min-width:88px;}
  .hub-src-row button{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 12px;cursor:pointer;font-weight:700;font-size:.84rem;}
  .hub-src-row button:hover{background:#fff3e2;}
  .tt-min{font-size:.8rem;color:var(--ink-soft);text-align:center;}
  .tt-legend{font-size:.74rem;color:var(--ink-soft);margin:4px 0 0;}
  .kind-chip{display:inline-block;padding:1px 8px;border-radius:999px;font-size:.72rem;font-weight:700;margin-right:6px;}
  .kc-lesson{background:#ffe5cf;color:#a85416;}
  .kc-meeting{background:#dcecf7;color:#2c5d80;}
  .kc-work{background:#dcefe2;color:#2c6a47;}
  .kc-break{background:#efe7d2;color:#7a6a3e;}

  /* よく使うタグ ボタン */
  .tagbar-wrap{border:1px dashed var(--line);border-radius:12px;padding:10px 12px;margin:10px 0;background:#fffdf8;}
  .tagbar-head{display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:8px;}
  .tagbar{display:flex;flex-wrap:wrap;gap:6px;}
  .tag-btn{display:inline-flex;align-items:center;gap:4px;border:1px solid var(--gold-soft);
    background:#fff3e2;color:var(--orange-deep);border-radius:999px;padding:5px 12px;cursor:pointer;
    font-weight:700;font-size:.8rem;transition:.12s;}
  .tag-btn:hover{background:#ffe6c9;transform:translateY(-1px);}
  .tag-btn .x{color:#c4441f;font-weight:800;opacity:.5;margin-left:2px;}
  .tag-btn .x:hover{opacity:1;}
  .tagbar-add{display:flex;gap:6px;margin-top:8px;align-items:center;}
  .tagbar-add input{flex:1;}
  .tagbar-add .mini-btn{flex:0 0 auto;border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 12px;cursor:pointer;font-weight:700;font-size:.8rem;}
  .calc{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:14px 0 4px;}
  .calc .cell{background:var(--paper);border:1px solid var(--line);border-radius:12px;
    padding:12px;text-align:center;box-shadow:var(--shadow);}
  .calc .num{font-size:1.35rem;font-weight:800;color:var(--orange-deep);line-height:1.2;}
  .calc .lab{font-size:.72rem;color:var(--ink-soft);margin-top:2px;}
  .bar{height:14px;border-radius:999px;background:#f1e3c9;overflow:hidden;margin:6px 0 2px;}
  .bar > i{display:block;height:100%;background:linear-gradient(90deg,var(--orange),var(--gold));width:0;transition:width .3s;}
  /* 区分別 内訳バー */
  .kindbar{display:flex;height:16px;border-radius:999px;overflow:hidden;margin:10px 0 4px;background:#f1e3c9;}
  .kindbar > span{height:100%;}
  .kb-lesson{background:#e0792b;} .kb-meeting{background:#3f7fae;} .kb-work{background:#3f8f5f;}

  /* 帰りのHR 自動励ましカード */
  .cheer-card{margin:14px 0 4px;border-radius:14px;padding:16px 18px;border:1px solid var(--line);
    background:linear-gradient(160deg,#fff6e9,#fff);display:none;animation:rise .4s ease both;}
  .cheer-card.show{display:block;}
  .cheer-card .emoji{font-size:1.6rem;}
  .cheer-card .title{font-weight:800;font-size:1.05rem;margin:4px 0;color:var(--orange-deep);}
  .cheer-card .msg{font-size:.92rem;color:var(--ink);}
  .cheer-card.lv-hanamaru{background:linear-gradient(160deg,#fff0f3,#fff7ea);border-color:#f3c6cf;}
  .cheer-card.lv-great{background:linear-gradient(160deg,#fff6e9,#fffdf5);}
  .cheer-card.lv-good{background:linear-gradient(160deg,#f3f9ff,#fff);border-color:#cfe2f0;}
  .cheer-card.lv-ok{background:linear-gradient(160deg,#f1f9f3,#fff);border-color:#cfe6d6;}

  /* 30日ログ（保存・入出力） */
  .log-actions{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0;}
  .log-actions button{border:1px solid var(--line);background:#fff7ee;color:var(--ink);
    border-radius:10px;padding:9px 14px;cursor:pointer;font-weight:700;font-size:.88rem;}
  .log-actions button:hover{background:#ffeede;}
  .log-actions .primary{background:linear-gradient(135deg,var(--orange),var(--orange-deep));color:#fff;border:none;}
  .log-actions .danger{background:#fff0ec;border-color:#ffc9b6;color:#c4441f;}
  .daylist{margin:6px 0;border:1px solid var(--line);border-radius:12px;overflow:hidden;}
  .daylist .empty{padding:14px;color:var(--ink-soft);font-size:.88rem;text-align:center;}
  .day-item{display:grid;grid-template-columns:1fr auto auto;gap:8px;align-items:center;
    padding:10px 12px;border-top:1px solid var(--line-soft);font-size:.86rem;}
  .day-item:first-child{border-top:none;}
  .day-item .meta{color:var(--ink-soft);font-size:.78rem;}
  .day-item .mini-btn{border:1px solid var(--line);background:#fff;border-radius:8px;padding:5px 10px;cursor:pointer;font-weight:700;font-size:.78rem;}
  .day-item .mini-btn.del{color:#c4441f;border-color:#ffc9b6;background:#fff5f2;width:auto;height:auto;}
  .agg{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:10px 0;}
  .agg .cell{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:12px;text-align:center;box-shadow:var(--shadow);}
  .agg .num{font-size:1.2rem;font-weight:800;color:var(--orange-deep);}
  .agg .lab{font-size:.72rem;color:var(--ink-soft);margin-top:2px;}
  .hidden-file{display:none;}

  /* スキルシート（案件欄） */
  .sk-block{border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin:10px 0;background:#fffdf8;}
  .sk-block .bk-head{display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap;}
  .sk-block .bk-title{font-weight:800;color:var(--orange-deep);font-size:.95rem;}
  .sk-guide{font-size:.74rem;color:var(--ink-soft);background:#fff3e2;border-radius:8px;padding:4px 8px;}
  .sk-count{font-size:.74rem;font-weight:700;color:var(--ink-soft);}
  .sk-count.warn{color:#c4441f;}
  .sk-count.okc{color:#2c7a52;}
  .sk-case{display:inline-block;font-weight:800;border-radius:999px;padding:2px 12px;font-size:.8rem;
    background:#ffe5cf;color:#a85416;}
  .sk-check label{display:flex;align-items:flex-start;gap:8px;font-weight:500;color:var(--ink);margin:7px 0;cursor:pointer;font-size:.88rem;}
  .sk-check input{width:auto;margin-top:3px;}
  .work-row{display:flex;gap:6px;align-items:center;margin:5px 0;}
  .work-row .idx{font-size:.78rem;color:var(--ink-soft);width:22px;text-align:right;flex:0 0 auto;}
  .work-row input{margin:0;}
  .work-row .del{flex:0 0 auto;}

  /* 進捗報告タスク行 */
  .ci-row{display:grid;grid-template-columns:1.6fr 92px 64px 1fr 32px;gap:6px;align-items:center;margin:5px 0;}
  .ci-row input,.ci-row select{margin:0;padding:7px 8px;font-size:.86rem;}
  .ci-row .del{width:32px;height:32px;}
  @media(max-width:640px){
    .ci-row{grid-template-columns:1fr 1fr 30px;}
    .ci-row .ci-name{grid-column:1 / -1;}
    .ci-row .ci-note{grid-column:1 / span 2;}
  }

  /* 一人MTG（PDCA） */
  .pdca-timer{background:linear-gradient(160deg,#fff6e9,#fffdf5);border:1px solid var(--line);
    border-radius:16px;padding:18px;text-align:center;box-shadow:var(--shadow);margin:12px 0;}
  .pdca-timer .clock{font-size:3rem;font-weight:800;color:var(--orange-deep);font-variant-numeric:tabular-nums;line-height:1.1;}
  .pdca-timer .phase{font-size:1.05rem;font-weight:800;margin-bottom:4px;}
  .pdca-timer .sub{font-size:.8rem;color:var(--ink-soft);margin-top:4px;}
  .pdca-timer.running{border-color:var(--orange);}
  .pdca-ctrl{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:12px;}
  .pdca-ctrl button{border:1px solid var(--line);background:#fff7ee;color:var(--ink);border-radius:10px;
    padding:9px 16px;cursor:pointer;font-weight:700;font-size:.9rem;}
  .pdca-ctrl button:hover{background:#ffeede;}
  .pdca-ctrl .primary{background:linear-gradient(135deg,var(--orange),var(--orange-deep));color:#fff;border:none;}
  .pdca-step{border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin:10px 0;background:#fffdf8;border-left:6px solid var(--gold);}
  .pdca-step.active{border-left-color:var(--orange);background:#fff5ea;}
  .pdca-step .hd{display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:6px;}
  .pdca-step .nm{font-weight:800;color:var(--orange-deep);}
  .pdca-step .mins{display:flex;align-items:center;gap:4px;font-size:.8rem;color:var(--ink-soft);}
  .pdca-step .mins input{width:54px;margin:0;padding:5px 6px;text-align:center;}
  .pdca-bar{height:8px;background:#f0e6d4;border-radius:999px;overflow:hidden;margin-top:8px;}
  .pdca-bar i{display:block;height:100%;background:linear-gradient(90deg,var(--orange),var(--gold));width:0;transition:width .3s;}

  /* 自由ひな形（日報） */
  .tpl-fields{border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin:10px 0;background:#fffdf8;}
  .tpl-fields .ph-row{display:grid;grid-template-columns:160px 1fr;gap:8px;align-items:start;margin:6px 0;}
  .tpl-fields .ph-row label{font-weight:700;color:var(--ink);padding-top:7px;font-size:.86rem;}
  .tpl-fields .ph-row textarea{min-height:40px;}
  .tpl-fields .empty{color:var(--ink-soft);font-size:.86rem;}
  .tpl-saved{display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin:8px 0;}
  .tpl-chip{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--gold-soft);
    background:#fff3e2;color:var(--orange-deep);border-radius:999px;padding:5px 12px;cursor:pointer;font-weight:700;font-size:.82rem;}
  .tpl-chip:hover{background:#ffe6c9;}
  .tpl-chip.cur{background:linear-gradient(135deg,var(--orange),var(--orange-deep));color:#fff;border:none;}
  .tpl-chip .x{opacity:.55;font-weight:800;}
  .tpl-chip .x:hover{opacity:1;color:#c4441f;}
  @media(max-width:640px){
    .tpl-fields .ph-row{grid-template-columns:1fr;}
    .tpl-fields .ph-row label{padding-top:0;}
    .agg{grid-template-columns:repeat(2,1fr);}
  }
  @media(max-width:640px){
    .grid,.grid3{grid-template-columns:1fr;}
    .task-row{grid-template-columns:1fr 1fr;}
    .task-row .t-purpose,.task-row .t-time{grid-column:span 2;}
    .bunny{font-size:28px;}
    .calc{grid-template-columns:repeat(2,1fr);}
    .tt-head{display:none;}
    .tt-row{grid-template-columns:1fr 1fr 30px;grid-auto-rows:auto;
      border:1px solid var(--line-soft);border-left-width:6px;border-radius:10px;padding:8px;background:#fffdf8;}
    .tt-row .tt-label{grid-column:1 / -1;font-weight:700;}
    .tt-row .tt-kind{grid-column:span 2;}
    .tt-row .tt-start,.tt-row .tt-end{grid-column:span 1;}
    .tt-row .tt-plan,.tt-row .tt-actual{grid-column:1 / -1;}
    .tt-row .tt-status{grid-column:span 2;}
    .tt-row .tt-min{grid-column:span 1;}
  }

  /* ===== ボタンのクリック挙動（影・押し込み） ===== */
  button{ transition:transform .08s ease, box-shadow .12s ease, filter .12s ease, background .12s ease; }
  /* 主要ボタンは通常時に軽い影、ホバーで浮き、クリックで沈む */
  .gen, .outbtns button, .log-actions button, .addbtn, .lang-btn,
  .pdca-ctrl button, .del, .ins-btn, .qtag, .ci-add, .sk-addbtn, .tpl-chip{
    box-shadow:0 2px 5px rgba(0,0,0,.08);
  }
  .gen:hover, .outbtns button:hover, .log-actions button:hover, .addbtn:hover, .lang-btn:hover,
  .pdca-ctrl button:hover, .del:hover, .ins-btn:hover, .qtag:hover, .tpl-chip:hover{
    box-shadow:0 4px 10px rgba(0,0,0,.14); transform:translateY(-1px);
  }
  /* クリック（押下）時：沈み込み＋内側の影で「押した」感触 */
  .gen:active, .outbtns button:active, .log-actions button:active, .addbtn:active, .lang-btn:active,
  .pdca-ctrl button:active, .del:active, .ins-btn:active, .qtag:active, .tab:active,
  .ci-add:active, .sk-addbtn:active, .tpl-chip:active, button:active{
    transform:translateY(1px) scale(.985);
    box-shadow:inset 0 3px 6px rgba(0,0,0,.18);
    filter:brightness(.97);
  }
  /* タブも軽い押し込み */
  .tab{ transition:transform .08s ease, box-shadow .12s ease, background .12s ease; }
  .tab:active{ transform:translateY(1px) scale(.99); }
  /* キーボード操作のフォーカスリング（アクセシビリティ） */
  button:focus-visible{ outline:2px solid var(--accent); outline-offset:2px; }
</style>
</head>
<body>
<div class="wrap">

  <header class="hero">
    <div class="hero-motif" aria-hidden="true">
      <!-- 日本版：トウモロコシ -->
      <svg class="motif-corn" viewBox="0 0 48 64" xmlns="http://www.w3.org/2000/svg">
