function readPeriods(){
  return [].slice.call(document.querySelectorAll("#ttList .tt-row")).map(function(r){
    var s=r.querySelector(".tt-start").value, e=r.querySelector(".tt-end").value;
    var sm=toMin(s), em=toMin(e);
    var raw=(sm!=null && em!=null && em>sm) ? (em-sm) : 0;
    var dur=round15(raw); // 15分単位に丸める
    var status=r.querySelector(".tt-status").value;
    var kind=r.querySelector(".tt-kind").value;
    var customEl=r.querySelector(".tt-custom");
    var customLabel=customEl ? customEl.value.trim() : "";
    var kindLabel = (kind==="other") ? (customLabel||"その他") : (KIND_LABEL[kind]||"作業");
    var insEl=r.querySelector(".tt-insflag");
    return {
      label:r.querySelector(".tt-label").value.trim(),
      kind:kind, kindLabel:kindLabel, customLabel:customLabel,
      s:s.trim(), e:e.trim(), dur:dur,
      plan:r.querySelector(".tt-plan").value.trim(),
      actual:r.querySelector(".tt-actual").value.trim(),
      status:status,
      isBreak:(kind==="break"),
      isInsert:!!(insEl&&insEl.checked)
    };
  });
}

