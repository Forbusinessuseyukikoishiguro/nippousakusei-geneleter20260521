function v(id){ var el=document.getElementById(id); return el ? (el.value||"").trim() : ""; }
function linesOf(id){
  var el=document.getElementById(id); if(!el) return [];
  return (el.value||"").split("\n").map(function(s){return s.trim();}).filter(Boolean);
}
function block(label, items, mark){
  // returns lines: each item prefixed with mark; empty -> nothing
  if(!items.length) return "";
  return items.map(function(s){ return mark + s; }).join("\n");
}
function today(){
  var d=new Date(), z=function(n){return (n<10?"0":"")+n;};
  return d.getFullYear()+z(d.getMonth()+1)+z(d.getDate());
}
// 曜日つき日付・時刻ヘルパ（自由ひな形の初期テンプレ用）
function nowParts(){
  var d=new Date(), z=function(n){return (n<10?"0":"")+n;};
  var w=["日","月","火","水","木","金","土"][d.getDay()];
  return {
    date: d.getFullYear()+"/"+z(d.getMonth()+1)+"/"+z(d.getDate())+"（"+w+"）", // 2026/05/21（木）
    dateJp: d.getFullYear()+"年"+(d.getMonth()+1)+"月"+d.getDate()+"日（"+w+"）",
    weekday: w+"曜日",
    time: z(d.getHours())+":"+z(d.getMinutes()),
    datetime: d.getFullYear()+"/"+z(d.getMonth()+1)+"/"+z(d.getDate())+"（"+w+"） "+z(d.getHours())+":"+z(d.getMinutes())
  };
}

