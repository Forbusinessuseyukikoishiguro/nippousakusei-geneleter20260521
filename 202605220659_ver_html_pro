  var insBtn=document.createElement("button"); insBtn.type="button"; insBtn.className="ins-btn"; insBtn.textContent="⤵"; insBtn.title="この下に差し込みコマを追加";
  insBtn.onclick=function(){ addPeriod({label:"割込", kind:"other", customLabel:"割込", isInsert:true}, row); };
  var del=document.createElement("button"); del.type="button"; del.className="del"; del.textContent="×";
  del.onclick=function(){ row.remove(); recalcTT(); };

  // 区分を変えたら行の色クラスを張り替え、休憩なら達成度を—に寄せる
  kindSel.addEventListener("change", function(){
