            <circle cx="17" cy="25" r="2.1"/><circle cx="22" cy="24" r="2.1"/><circle cx="27" cy="24" r="2.1"/><circle cx="31" cy="25" r="2.1"/>
            <circle cx="17" cy="32" r="2.1"/><circle cx="22" cy="31" r="2.1"/><circle cx="27" cy="31" r="2.1"/><circle cx="31" cy="32" r="2.1"/>
            <circle cx="18" cy="39" r="2.1"/><circle cx="23" cy="38" r="2.1"/><circle cx="28" cy="38" r="2.1"/>
            <circle cx="20" cy="46" r="2"/><circle cx="25" cy="45" r="2"/>
          </g>
          <!-- ひげ -->
          <path d="M22 6 C20 1 18 1 16 3 M24 5 C24 0 26 0 27 2 M26 6 C28 1 31 2 31 4" stroke="var(--gold)" stroke-width="1.4" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
      <!-- 英語版（カナダ）：紅葉（メープルリーフ） -->
      <svg class="motif-maple" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <path fill="var(--accent)" d="M50 6
 c0 4 2 7 5 6 l-2 8 9-3 -1 6 7-2 -3 9 7-1 -4 9 9-2 -2 7 6-1 -8 14 13-2 0 5 -16 2 1 4 -13 3 7 9 -10-2 1 11 -7-6 -7 6 1-11 -10 2 7-9 -13-3 1-4 -16-2 0-5 13 2 -8-14 6 1 -2-7 9 2 -4-9 7 1 -3-9 7 2 -1-6 9 3 -2-8 c3 1 5-2 5-6 z"/>
      </svg>
    </div>
    <div class="lang-switch">
      <button type="button" id="langJp" class="lang-btn active" onclick="setLang('jp')">🇯🇵 日本語</button>
      <button type="button" id="langEn" class="lang-btn" onclick="setLang('en')">🇬🇧 English</button>
    </div>
    <div class="bunny">🐰</div>
    <h1 data-i18n="title">うさうさ 日報作成ジェネレーター</h1>
    <p data-i18n="subtitle">登録不要・インストール不要。ブラウザだけで日報・ふりかえり・スキルシート・月末の工数集計まで作れる無料ツールです。入力した内容はあなたの端末の中だけに保存され、どこにも送信されません。</p>
  </header>

  <div class="tabs">
    <div class="tab active" data-tab="report">📋 退勤前報告（業務日報）</div>
    <div class="tab" data-tab="memo">📝 メモ版 日報・進捗</div>
    <div class="tab" data-tab="chat">💬 相談チャットテンプレ</div>
    <div class="tab" data-tab="timetable">🏫 時間割（HR学校風）</div>
    <div class="tab" data-tab="skill">📐 スキルシート（案件欄）</div>
    <div class="tab" data-tab="pdca">🔄 一人MTG（PDCA）</div>
    <div class="tab" data-tab="mtg2">🎯 一人MTG2（目標・KPT）</div>
    <div class="tab" data-tab="tpl">🧩 自由ひな形（日報）</div>
    <div class="tab" data-tab="hub">🗂 月次データ統合</div>
  </div>

  <!-- ============ TAB 1: 退勤前報告 ============ -->
  <div class="panel active" id="panel-report">
    <h2>① 基本情報</h2>
    <div class="grid">
      <div><label>日付</label><input id="r_date" placeholder="2026年4月1日(水)"></div>
      <div><label>氏名</label><input id="r_name" placeholder="友季子" value="友季子"></div>
    </div>
    <div class="grid3">
      <div><label>場所</label>
        <select id="r_place"><option>対面</option><option>リモート</option><option>在宅</option><option>ハイブリッド</option></select>
      </div>
      <div><label>勤務時間（開始〜終了）</label><input id="r_time" placeholder="9:00～18:00"></div>
      <div><label>実働</label><input id="r_hours" placeholder="8h"></div>
    </div>

    <h2 style="margin-top:24px;">② 本日の業務内容</h2>
    <p class="hint">タスクごとに 状態・目的・所要時間 を入力。状態は 完了／対応中／未完了。</p>
    <div id="taskList"></div>
    <button type="button" class="addbtn" onclick="addTask()">＋ タスクを追加</button>

    <h2 style="margin-top:24px;">③ 成果・進捗</h2>
    <div class="grid3">
      <div><label>今日の成果物</label><input id="r_deliver" placeholder="◯◯を完成"></div>
      <div><label>進捗率</label><input id="r_rate" placeholder="80%"></div>
      <div><label>KPIに対する進捗</label><input id="r_kpi" placeholder="週次目標の60%"></div>
    </div>

    <h2 style="margin-top:24px;">④ 課題・問題点</h2>
    <p class="hint">該当しない欄は空のままでOK（空欄は出力されません）。</p>
    <div class="grid">
      <div><label>1. 発生した問題</label><textarea id="r_p1"></textarea></div>
      <div><label>2. 前提・背景</label><textarea id="r_p2"></textarea></div>
      <div><label>3. やりたいこと</label><textarea id="r_p3"></textarea></div>
      <div><label>4. 解決方法</label><textarea id="r_p4"></textarea></div>
      <div><label>5. 環境</label><textarea id="r_p5"></textarea></div>
      <div><label>6. 原因（仮説）</label><textarea id="r_p6"></textarea></div>
    </div>
    <label>7. 影響範囲</label><textarea id="r_p7"></textarea>

    <h2 style="margin-top:24px;">⑤ 対応・アクション</h2>
    <label>明日の対応予定</label><textarea id="r_action"></textarea>

    <h2 style="margin-top:24px;">⑥ 学び・気づき</h2>
    <div class="grid">
      <div><label>今日の学び</label><textarea id="r_learn"></textarea></div>
      <div><label>次に活かすこと</label><textarea id="r_next"></textarea></div>
    </div>

    <h2 style="margin-top:24px;">⑦ 共有事項（上長・関係者向け）</h2>
    <div class="grid3">
      <div><label>報告事項</label><textarea id="r_share"></textarea></div>
      <div><label>相談事項</label><textarea id="r_consult"></textarea></div>
      <div><label>支援依頼</label><textarea id="r_help"></textarea></div>
    </div>

    <h2 style="margin-top:24px;">⑧ 明日の予定</h2>
    <div class="grid3">
      <div><label>タスク</label><textarea id="r_tmtask"></textarea></div>
      <div><label>想定時間</label><input id="r_tmtime" placeholder="09:00〜18:00（在宅）"></div>
      <div><label>優先順位</label><textarea id="r_tmprio"></textarea></div>
    </div>

    <button class="gen" onclick="buildReport()">📋 業務日報を生成する</button>
  </div>

  <!-- ============ TAB 2: メモ版 ============ -->
  <div class="panel" id="panel-memo">
    <h2>ヘッダ</h2>
    <div class="grid3">
      <div><label>日付</label><input id="m_date" placeholder="2026/04/01（水）"></div>
      <div><label>役割</label>
        <select id="m_role"><option>IT研修講師</option><option>社内SE</option><option>SES</option><option>IT営業</option></select>
      </div>
      <div><label>気分</label>
        <select id="m_mood"><option>😀</option><option>😐</option><option>😣</option></select>
      </div>
    </div>
    <label>一言</label><input id="m_word" value="面白きこともなき世を面白く">

    <label class="toggle"><input type="checkbox" id="m_tt_on"> 🕘 タイムテーブルを含める</label>
    <div class="collapsible" id="m_tt_wrap">
      <p class="hint">1行ずつ自由記入（例：09:00-10:00 ｜ 朝会・メール処理）。空なら標準枠を出力します。</p>
      <textarea id="m_tt" style="min-height:120px"></textarea>
    </div>

    <h2 style="margin-top:22px;">✅ 今日すること</h2>
    <p class="hint">1行＝1項目。チェックボックス [ ] が自動で付きます。</p>
    <label>メイン業務</label><textarea id="m_today_main"></textarea>
    <label>メイン業務以外（学習・整備・社内貢献）</label><textarea id="m_today_sub"></textarea>
    <label>趣味枠（個人開発・記事・インプット）</label><textarea id="m_today_hobby"></textarea>
    <label>今日 相談すること（@誰に / 何を / なぜ / 口頭 or Slack）</label><textarea id="m_today_talk"></textarea>

    <h2 style="margin-top:22px;">📊 作業進捗</h2>
    <label>✓ 完了したこと</label><textarea id="m_done"></textarea>
    <label>→ 着手中・持ち越し</label><textarea id="m_wip"></textarea>
    <h3>⚠ ブロッカー / 詰まり</h3>
    <div class="grid">
      <div><label>内容</label><input id="m_bl_what"></div>
      <div><label>影響</label><input id="m_bl_eff"></div>
      <div><label>必要なアクション</label><input id="m_bl_act"></div>
      <div><label>相手</label><input id="m_bl_who"></div>
    </div>

    <h2 style="margin-top:22px;">🚩 依頼・相談 一覧</h2>
    <label>📨 サポート依頼（@誰／内容／期限／状態）</label><textarea id="m_req_sup"></textarea>
    <label>🔍 レビュー依頼（@誰／URL／観点／期限）</label><textarea id="m_req_rev"></textarea>
    <label>👥 他の人と相談が必要（関係者／議題／形式／いつ）</label><textarea id="m_req_talk"></textarea>
    <label>💭 その他・気になっていること</label><textarea id="m_req_etc"></textarea>

    <h2 style="margin-top:22px;">📅 明日すること</h2>
    <label>メイン業務</label><textarea id="m_tm_main"></textarea>
    <label>メイン業務以外</label><textarea id="m_tm_sub"></textarea>
    <label>趣味枠</label><textarea id="m_tm_hobby"></textarea>
    <label>明日 相談すること</label><textarea id="m_tm_talk"></textarea>

    <label class="toggle"><input type="checkbox" id="m_wk_on"> 🗓 今週／来週も含める（金曜の棚卸し用）</label>
    <div class="collapsible" id="m_wk_wrap">
      <label>今週すること（残り・メイン）</label><textarea id="m_wk_main"></textarea>
      <label>今週すること（以外・趣味）</label><textarea id="m_wk_sub"></textarea>
      <label>来週すること（メイン）</label><textarea id="m_nw_main"></textarea>
      <label>来週すること（以外・趣味）</label><textarea id="m_nw_sub"></textarea>
    </div>

    <label class="toggle"><input type="checkbox" id="m_mo_on"> 📆 今月／来月も含める（月初・月末用）</label>
    <div class="collapsible" id="m_mo_wrap">
      <label>今月すること（月次目標）</label><textarea id="m_mo_main"></textarea>
      <label>今月すること（以外・趣味）</label><textarea id="m_mo_sub"></textarea>
      <label>来月すること</label><textarea id="m_nm_main"></textarea>
    </div>

    <h2 style="margin-top:22px;">🩺 デイリー習慣</h2>
    <div class="checks" id="m_habits">
      <label><input type="checkbox" value="☕ 休憩10分 × 社内記事ドラフト1段落"> ☕ 休憩10分 × 社内記事ドラフト1段落</label>
      <label><input type="checkbox" value="🏁 定時退社（残業せず帰る）"> 🏁 定時退社（残業せず帰る）</label>
      <label><input type="checkbox" value="📝 明日のタスクを書き切ってからPCを閉じる"> 📝 明日のタスクを書き切ってからPCを閉じる</label>
      <label><input type="checkbox" value="🧹 受信トレイ／DMをゼロ（既読＋ピン整理）"> 🧹 受信トレイ／DMをゼロ（既読＋ピン整理）</label>
      <label><input type="checkbox" value="🌙 持ち帰り思考をしない"> 🌙 持ち帰り思考をしない</label>
    </div>

    <h2 style="margin-top:22px;">🧠 退社前 1分セルフチェック</h2>
    <div class="checks" id="m_self">
      <label><input type="checkbox" value="今日の3大ToDoのうち最低1つは完了した"> 今日の3大ToDoのうち最低1つは完了した</label>
      <label><input type="checkbox" value="😰 を抱えたまま帰ろうとしていない"> 😰 を抱えたまま帰ろうとしていない</label>
      <label><input type="checkbox" value="明日の最初の30分で着手することが決まっている"> 明日の最初の30分で着手することが決まっている</label>
      <label><input type="checkbox" value="来週繰越すべきタスクを「今週すること」に書いた"> 来週繰越すべきタスクを「今週すること」に書いた</label>
    </div>

    <button class="gen" onclick="buildMemo()">📝 メモ版を生成する</button>
  </div>

  <!-- ============ TAB 3: 相談チャット ============ -->
  <div class="panel" id="panel-chat">
    <h2>相談チャットテンプレ（Slack / Mattermost コピペ用）</h2>
    <label>テンプレを選ぶ</label>
    <select id="c_tpl" onchange="switchTpl()">
      <option value="A">A：相談（判断を仰ぐ）</option>
      <option value="B">B：質問（教えてほしい）</option>
      <option value="C">C：レビュー依頼</option>
      <option value="D">D：即時報告（障害／クレーム）</option>
      <option value="E">E：連絡（返信不要）</option>
      <option value="F">F：他の人と相談したい（巻き込み）</option>
      <option value="G">G：朝会・夕会の簡易日報</option>
      <option value="H">H：営業向け お礼＋次アクション</option>
      <option value="I">I：進捗報告（ステータス・％／1分・3分・5分・PREP）</option>
    </select>

    <div class="tpl" data-tpl="A">
      <label>状況</label><textarea id="cA_sit"></textarea>
      <div class="grid"><div><label>選択肢A</label><input id="cA_a"></div><div><label>選択肢B</label><input id="cA_b"></div></div>
      <label>私の推し案（理由）</label><input id="cA_push" placeholder="A寄り（理由：）">
      <label>ほしい判断</label><input id="cA_want" value="OK / NG / 別案">
    </div>
    <div class="tpl" data-tpl="B" style="display:none">
      <label>あなたの名前</label><input id="cB_name" value="友季子">
      <label>何について</label><input id="cB_topic">
      <label>何が分からないか</label><textarea id="cB_q"></textarea>
      <label>自分で確認したこと</label><textarea id="cB_done"></textarea>
      <div class="grid"><div><label>いつまでに方針が欲しいか</label><input id="cB_due"></div><div><label>業務影響</label><input id="cB_eff"></div></div>
    </div>
    <div class="tpl" data-tpl="C" style="display:none">
      <label>対象URL</label><input id="cC_url">
      <div class="grid"><div><label>見てほしい観点1</label><input id="cC_p1"></div><div><label>観点2</label><input id="cC_p2"></div></div>
      <label>期限</label><input id="cC_due" placeholder="YYYY/MM/DD HH:MM まで">
      <label>補足</label>
      <select id="cC_note"><option>ザッと見でOK</option><option>詳細指摘歓迎</option><option>どちらでも</option></select>
    </div>
    <div class="tpl" data-tpl="D" style="display:none">
      <label>事実</label><textarea id="cD_fact"></textarea>
      <label>影響範囲</label><textarea id="cD_eff"></textarea>
      <label>現在の対応</label><textarea id="cD_act"></textarea>
      <label>判断ほしい点</label><textarea id="cD_want"></textarea>
    </div>
    <div class="tpl" data-tpl="E" style="display:none">
      <label>変更・連絡内容</label><input id="cE_what" placeholder="◯◯を◯◯に変更しました">
      <label>関連URL</label><input id="cE_url">
      <label>影響</label><select id="cE_eff"><option>軽微</option><option>なし</option></select>
    </div>
    <div class="tpl" data-tpl="F" style="display:none">
      <label>件名・議題</label><textarea id="cF_topic"></textarea>
      <div class="grid"><div><label>△△さん（必要な理由）</label><input id="cF_p1"></div><div><label>□□さん（必要な理由）</label><input id="cF_p2"></div></div>
      <div class="grid"><div><label>形式</label><select id="cF_form"><option>1on1</option><option>グループMTG</option><option>非同期スレッド</option></select></div>
      <div><label>いつ頃</label><select id="cF_when"><option>本日中</option><option>今週中</option><option>来週前半</option></select></div></div>
    </div>
    <div class="tpl" data-tpl="G" style="display:none">
      <label>日付</label><input id="cG_date" placeholder="2026/04/01（水）">
      <label>昨日</label><textarea id="cG_y"></textarea>
      <label>今日</label><textarea id="cG_t"></textarea>
