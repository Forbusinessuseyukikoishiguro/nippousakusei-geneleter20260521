var SK_DRAFT={ items:[], dates:[], goals:[], kindMin:{lesson:0,meeting:0,work:0}, custom:{} };

// 作業項目の正規化：先頭の記号・チェックボックス・状態語を落とし、動詞語尾に寄せる
function normWorkItem(s){
  if(!s) return "";
  s=s.replace(/^[\s　]*([\-・*※▼●□■◆◎○△➡→\u2022]|\[[ xX]?\]|\d+[\.\)）]|[#＃]\S+)\s*/,"");
  s=s.replace(/[#＃]\S+/g,"").trim();       // 文中タグ除去
  s=s.replace(/^(完了|対応中|未着手|未完了|done|完了：|実績：|予定：)\s*/i,"");
  s=s.replace(/（[^）]*\d{1,2}:\d{2}[^）]*）/g,""); // 時刻括弧除去
  s=s.replace(/[。\.]$/,"").trim();
  return s;
}
function isMeaningful(s){
  if(!s) return false;
  s=s.trim();
  if(s.length<2) return false;                 // 1文字は除外（2文字の業務名「採点」「設計」等は許容）
  if(/^[\d\s:：.、,。]+$/.test(s)) return false;  // 数字・記号だけは除外
  if(/^(なし|特になし|無し|特に無し|休憩|昼休み|昼食|ー|-|—|・|済|完了|なんとなく)$/.test(s)) return false; // ノイズ語
  return true;
}

// 30日ログ（時間割保存データ）から候補を集める
function skCollectFromLog(){
  var days=loadDays();
  var items=[], dates=[], goals=[], kindMin={lesson:0,meeting:0,work:0}, custom={};
  days.forEach(function(d){
    if(d.date) dates.push(d.date);
    if(d.goal) goals.push(d.goal);
    if(d.kindMin){ kindMin.lesson+=d.kindMin.lesson||0; kindMin.meeting+=d.kindMin.meeting||0; kindMin.work+=d.kindMin.work||0; }
    if(d.customMin){ Object.keys(d.customMin).forEach(function(k){ custom[k]=(custom[k]||0)+d.customMin[k]; }); }
    (d.periods||[]).forEach(function(p){
      if(p.kind==="break"||p.isBreak) return;
      [p.actual,p.plan].forEach(function(txt){
        var n=normWorkItem(txt);
        if(isMeaningful(n)) items.push(n);
      });
    });
  });
  return {items:items, dates:dates, goals:goals, kindMin:kindMin, custom:custom};
}

// 自由テキスト/CSVから候補を集める（行ベース）
function skCollectFromText(text){
  var items=[], dates=[];
  (text||"").split(/\r?\n/).forEach(function(raw){
    var line=raw.trim(); if(!line) return;
    // 日付行を拾う
    var dm=/(\d{4})\D+(\d{1,2})\D+(\d{1,2})/.exec(line);
    if(dm && line.replace(/[\d\/\-\.年月日（）\(\)月火水木金土曜\s]/g,"").length<=2){
      dates.push(line); return;
    }
    // CSVっぽい場合はカンマ分割して各セルも候補に
    var cells = line.indexOf(",")>=0 ? line.split(",") : [line];
    cells.forEach(function(c){
      var n=normWorkItem(c);
      if(isMeaningful(n)) items.push(n);
    });
  });
  return {items:items, dates:dates, goals:[], kindMin:{lesson:0,meeting:0,work:0}, custom:{}};
}

// 候補の集約：正規化して重複は回数カウント、頻度順
function skAggregate(collected){
  var map={}; // text -> count
  collected.items.forEach(function(t){ map[t]=(map[t]||0)+1; });
  var uniq=Object.keys(map).sort(function(a,b){ return map[b]-map[a] || a.localeCompare(b); });
  SK_DRAFT={ items:uniq, counts:map, dates:collected.dates||[], goals:collected.goals||[],
    kindMin:collected.kindMin||{lesson:0,meeting:0,work:0}, custom:collected.custom||{} };
  skRenderCandidates();
}

