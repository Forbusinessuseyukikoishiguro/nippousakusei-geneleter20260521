/* ===== .xlsx 最小リーダー（DecompressionStream利用・先頭シートのみ） ===== */
// 注意：書き込み用の _u16/_u32（数値→バイト配列）と名前が衝突しないよう別名にする
function _ru16(b,o){ return b[o]|(b[o+1]<<8); }
function _ru32(b,o){ return (b[o]|(b[o+1]<<8)|(b[o+2]<<16)|(b[o+3]<<24))>>>0; }
async function _inflateRaw(bytes){
  var ds=new window.DecompressionStream("deflate-raw");
  var w=ds.writable.getWriter(); w.write(bytes); w.close();
  var ab=await new Response(ds.readable).arrayBuffer();
  return new Uint8Array(ab);
}
// ZIPのローカルエントリを走査して {name: Uint8Array} を返す（STORED/deflate対応）
async function _unzip(bytes){
  var files={}, i=0, n=bytes.length;
  while(i+4<=n && _ru32(bytes,i)===0x04034b50){
    var method=_ru16(bytes,i+8);
    var compSize=_ru32(bytes,i+18);
    var nameLen=_ru16(bytes,i+26);
    var extraLen=_ru16(bytes,i+28);
    var nameStart=i+30;
    var name=new TextDecoder().decode(bytes.subarray(nameStart, nameStart+nameLen));
    var dataStart=nameStart+nameLen+extraLen;
    var comp=bytes.subarray(dataStart, dataStart+compSize);
    var data;
    if(method===0){ data=comp; }
    else if(method===8){ try{ data=await _inflateRaw(comp); }catch(e){ data=null; } }
    else { data=null; }
    if(data) files[name]=data;
    i=dataStart+compSize;
  }
  return files;
}
function _xmlText(s){
  s=s.replace(/&#x([0-9a-fA-F]+);/g,function(_,h){return String.fromCodePoint(parseInt(h,16));})
     .replace(/&#(\d+);/g,function(_,d){return String.fromCodePoint(parseInt(d,10));});
  return s.replace(/&lt;/g,"<").replace(/&gt;/g,">").replace(/&quot;/g,'"').replace(/&apos;/g,"'").replace(/&amp;/g,"&");
}
async function _xlsxToRows(bytes){
  var files=await _unzip(bytes);
  if(!files["xl/worksheets/sheet1.xml"]) return [];
  var dec=new TextDecoder();
  // sharedStrings
  var shared=[];
  if(files["xl/sharedStrings.xml"]){
    var sx=dec.decode(files["xl/sharedStrings.xml"]);
    sx.replace(/<si>([\s\S]*?)<\/si>/g, function(_,inner){
      var txt=""; inner.replace(/<t[^>]*>([\s\S]*?)<\/t>/g, function(__,t){ txt+=t; return ""; });
      shared.push(_xmlText(txt)); return "";
    });
  }
  var sheet=dec.decode(files["xl/worksheets/sheet1.xml"]);
  var rows=[];
  sheet.replace(/<row[^>]*>([\s\S]*?)<\/row>/g, function(_,rowXml){
    var cells=[];
    rowXml.replace(/<c([^>]*)>([\s\S]*?)<\/c>/g, function(__,attr,cv){
      var tMatch=/t="([^"]+)"/.exec(attr);
      var t=tMatch?tMatch[1]:"";
      var val="";
      if(t==="inlineStr"){
        // <is><t>...</t></is>（複数tも連結）
        cv.replace(/<t[^>]*>([\s\S]*?)<\/t>/g, function(_2,tt){ val+=tt; return ""; });
        val=_xmlText(val);
      } else {
        var vMatch=/<v>([\s\S]*?)<\/v>/.exec(cv);
        val=vMatch?vMatch[1]:"";
        if(t==="s"){ val=shared[parseInt(val,10)]||""; }
        else { val=_xmlText(val); }
      }
      cells.push(val);
      return "";
    });
    rows.push(cells);
    return "";
  });
  return rows;
}

function _parseCsv(text){
  text=text.replace(/^\uFEFF/,"");
  var rows=[], row=[], cur="", inq=false;
  for(var i=0;i<text.length;i++){
    var ch=text[i];
    if(inq){
      if(ch==='"'){ if(text[i+1]==='"'){ cur+='"'; i++; } else { inq=false; } }
      else { cur+=ch; }
    } else {
      if(ch==='"'){ inq=true; }
      else if(ch===','){ row.push(cur); cur=""; }
      else if(ch==='\n'){ row.push(cur); rows.push(row); row=[]; cur=""; }
      else if(ch==='\r'){ /* skip */ }
      else { cur+=ch; }
    }
  }
  if(cur.length||row.length){ row.push(cur); rows.push(row); }
  return rows.filter(function(r){ return r.some(function(c){return c!=="";}); });
}
var KIND_FROM_LABEL={"授業":"lesson","会議":"meeting","作業":"work","休憩":"break"};
function importCsv(input){
  var file=input.files&&input.files[0];
  if(!file){ return; }
  var reader=new FileReader();
  reader.onload=function(){
    try{
      var rows=_parseCsv(String(reader.result));
      if(rows.length<2){ toast("データが見つかりません"); return; }
      var header=rows[0].map(function(s){return s.trim();});
      var ix={};
      ["日付","時限","区分","開始","終了","予定分","予定","実績","達成"].forEach(function(h){ ix[h]=header.indexOf(h); });
      if(ix["日付"]<0){ toast("ヘッダに「日付」がありません"); return; }
      var byDate={};
      rows.slice(1).forEach(function(r){
        var date=(r[ix["日付"]]||"").trim(); if(!date) return;
        if(!byDate[date]) byDate[date]={date:date, periods:[]};
        var kindLabel=(ix["区分"]>=0?(r[ix["区分"]]||"").trim():"作業");
        var kind=KIND_FROM_LABEL[kindLabel];
        var customLabel="";
        if(!kind){ kind="other"; customLabel=kindLabel||"その他"; } // 未知ラベルはその他
        byDate[date].periods.push({
          label:(ix["時限"]>=0?r[ix["時限"]]:"")||"",
          kind:kind, kindLabel:kindLabel||"その他", customLabel:customLabel,
          s:(ix["開始"]>=0?r[ix["開始"]]:"")||"", e:(ix["終了"]>=0?r[ix["終了"]]:"")||"",
          plan:(ix["予定"]>=0?r[ix["予定"]]:"")||"", actual:(ix["実績"]>=0?r[ix["実績"]]:"")||"",
          status:((ix["達成"]>=0?r[ix["達成"]]:"")||"◎")||"◎"
        });
      });
      // 各日の集計を再計算してレコード化
      var days=Object.keys(byDate).map(function(date){ return recomputeRecord(byDate[date]); });
      days.sort(function(a,b){ return a.date<b.date?-1:(a.date>b.date?1:0); });
      // 既存とマージ（同日付は上書き）
      var existing=loadDays();
      var map={}; existing.forEach(function(d){ map[d.date]=d; });
      days.forEach(function(d){ map[d.date]=d; });
      var merged=Object.keys(map).map(function(k){return map[k];}).sort(function(a,b){return a.date<b.date?-1:(a.date>b.date?1:0);});
      storeDays(merged);
      renderDayList();
      // 最新日をフォームへ
      if(merged.length){ loadDayToForm(merged[merged.length-1].date); }
      toast(days.length+"日分を取り込みました");
    }catch(e){ toast("読み込みに失敗しました"); }
    input.value="";
  };
  reader.readAsText(file,"UTF-8");
}
// periods配列だけのオブジェクトから、集計込みのレコードを再構築
function recomputeRecord(obj){
  var kindMin={lesson:0,meeting:0,work:0}, customMin={}, breakMin=0, slots=0, planMin=0, actMin=0, cO=0,cMaru=0,cTri=0,cBrk=0;
  (obj.periods||[]).forEach(function(p){
    var dur=p.dur;
    if(dur==null||dur===""){ var sm=toMin(p.s), em=toMin(p.e); dur=(sm!=null&&em!=null&&em>sm)?(em-sm):0; }
    dur=round15(parseInt(dur,10)||0); p.dur=dur; // 15分丸め
    if(p.kind==="break"){ cBrk++; breakMin+=dur; return; }
    slots++; planMin+=dur;
    if(p.kind==="other"){ var nm=p.customLabel||p.kindLabel||"その他"; customMin[nm]=(customMin[nm]||0)+dur; }
    else if(kindMin[p.kind]!=null){ kindMin[p.kind]+=dur; }
    if(p.status==="◎"){ cO++; actMin+=dur; }
    else if(p.status==="○"){ cMaru++; actMin+=dur*0.5; }
    else if(p.status==="△"){ cTri++; }
  });
  return {
    date:obj.date, mood:obj.mood||"", place:obj.place||"", goal:obj.goal||"", word:obj.word||"",
    keep:obj.keep||"", problem:obj.problem||"", tryv:obj.tryv||"", teacher:obj.teacher||"",
    slots:slots, planMin:planMin, actMin:Math.round(actMin),
    rate: planMin>0?Math.round(actMin/planMin*100):0,
    cO:cO,cMaru:cMaru,cTri:cTri,cBrk:cBrk, kindMin:kindMin, customMin:customMin, breakMin:breakMin,
    periods:obj.periods||[]
  };
}
