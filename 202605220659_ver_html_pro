function recalcTT(){
  var rows=readPeriods();
  var domRows=document.querySelectorAll("#ttList .tt-row");
  var slots=0, planMin=0, actMin=0, cO=0,cMaru=0,cTri=0,cBrk=0;
  var kindMin={lesson:0,meeting:0,work:0}; // 固定区分の予定稼働時間
  var customMin={}; // カスタム区分名ごとの予定稼働時間
  var insCount=0, insMin=0; // 差し込み（割込）コマ数・時間
  rows.forEach(function(r,i){
    var dur=r.dur;
    if(domRows[i]) domRows[i].querySelector(".tt-min").textContent = dur? dur+"分" : "-";
    if(r.kind==="break"){ cBrk++; return; }
    slots++; planMin+=dur;
    if(r.isInsert){ insCount++; insMin+=dur; }
    if(r.kind==="other"){ var nm=r.kindLabel||"その他"; customMin[nm]=(customMin[nm]||0)+dur; }
    else if(kindMin[r.kind]!=null){ kindMin[r.kind]+=dur; }
    if(r.status==="◎"){ cO++; actMin+=dur; }
    else if(r.status==="○"){ cMaru++; actMin+=dur*0.5; }
    else if(r.status==="△"){ cTri++; }
  });
  var rate = planMin>0 ? Math.round(actMin/planMin*100) : 0;
  document.getElementById("c_slots").textContent=slots;
  document.getElementById("c_plan").textContent=fmtHM(planMin);
  document.getElementById("c_actual").textContent=fmtHM(Math.round(actMin));
  document.getElementById("c_rate").textContent=rate+"%";
  document.getElementById("c_barfill").style.width=Math.min(rate,100)+"%";
  document.getElementById("c_breakdown").textContent="◎"+cO+" ／ ○"+cMaru+" ／ △"+cTri+" ／ 休憩"+cBrk+(insCount?(" ／ ⚡差込"+insCount):"");

  // 区分別 内訳バー
  var kb=document.getElementById("c_kindbar");
  if(kb){
    kb.innerHTML="";
    [["lesson","kb-lesson"],["meeting","kb-meeting"],["work","kb-work"]].forEach(function(p){
      var w=planMin>0 ? (kindMin[p[0]]/planMin*100) : 0;
      if(w>0){ var sp=document.createElement("span"); sp.className=p[1]; sp.style.width=w+"%"; kb.appendChild(sp); }
    });
    var custTxt=Object.keys(customMin).map(function(k){return k+" "+fmtHM(customMin[k]);}).join(" ／ ");
    document.getElementById("c_kindlabel").textContent=
      "区分別 予定時間（"+unitLabel()+"／"+modeLabel()+"）：授業 "+fmtHM(kindMin.lesson)+" ／ 会議 "+fmtHM(kindMin.meeting)+" ／ 作業 "+fmtHM(kindMin.work)+(custTxt?(" ／ "+custTxt):"");
  }

  // タグ別 時間集計（#タグ）
  var tagMin=tagMinutesFromPeriods(rows);
  var tagKeys=Object.keys(tagMin).sort(function(a,b){return tagMin[b]-tagMin[a];});
  var tl=document.getElementById("c_taglabel");
  if(tl){
    var parts=[];
    if(tagKeys.length){ parts.push("タグ別 時間：" + tagKeys.map(function(k){return "#"+k+" "+fmtHM(tagMin[k]);}).join(" ／ ")); }
    if(insCount){ parts.push("⚡差し込み対応："+insCount+"件・"+fmtHM(insMin)); }
    if(parts.length){ tl.style.display="block"; tl.textContent=parts.join("　|　"); }
    else { tl.style.display="none"; }
  }

  renderCheer(rate, slots);

  return {slots:slots,planMin:planMin,actMin:Math.round(actMin),rate:rate,
    cO:cO,cMaru:cMaru,cTri:cTri,cBrk:cBrk,kindMin:kindMin,customMin:customMin,tagMin:tagMin,
    insCount:insCount,insMin:insMin};
}

