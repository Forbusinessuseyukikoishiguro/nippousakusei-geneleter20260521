// 1行から所要時間（分）を抽出。「（90分）」「90分」「1h」「1:30」「1時間30分」などに対応
function parseMinutes(line){
  if(!line) return 0;
  var total=0, matched=false;
  // 1時間30分 / 2時間 / 1h（時間＋任意の分）
  var hh=/(\d+(?:\.\d+)?)\s*(?:時間|hr|h|時)/i.exec(line);
  if(hh){ total += Math.round(parseFloat(hh[1])*60); matched=true; }
  // 分（90分 / 45min / 30m）。日本語の「分」は語境界が効かないので \b を使わない
  var mm=/(\d+)\s*(?:分|min|m)(?![a-z])/i.exec(line);
  if(mm){ total += parseInt(mm[1],10); matched=true; }
  // 上で取れなければ 1:30（時:分）形式
  if(!matched){
    var hm=/(\d{1,2}):(\d{2})/.exec(line);
    if(hm){ total += parseInt(hm[1],10)*60+parseInt(hm[2],10); matched=true; }
  }
  return matched? total : 0;
}
// タスク名の正規化（時間表記・タグ・先頭記号を落とす）
function memoTaskName(line){
  var s=line;
  s=s.replace(/[（(]\s*\d+(?:\.\d+)?\s*(?:時間|分|h|hr|min|m)\s*[)）]/gi,""); // （90分）等の括弧つき
  s=s.replace(/\d{1,2}:\d{2}/g,"");                 // 1:30
  s=s.replace(/\d+(?:\.\d+)?\s*(?:時間|h|hr|時)\s*(?:\d+\s*(?:分|min|m))?/gi,""); // 1時間30分/2h
  s=s.replace(/\d+\s*(?:分|min|m)(?![a-z])/gi,"");          // 90分
  s=normWorkItem(s);                                 // 記号・タグ・状態語除去（既存）
  return s;
}
// メモ全体を解析：{taskMin, tagMin, dates, items}
function analyzeMemo(text){
  var taskMin={}, tagMin={}, dates=[], items=[];
  (text||"").split(/\r?\n/).forEach(function(raw){
    var line=raw.trim(); if(!line) return;
    // 日付行
    var dm=/(\d{4})\D+(\d{1,2})\D+(\d{1,2})/.exec(line);
    if(dm && line.replace(/[\d\/\-\.年月日（）\(\)月火水木金土曜\s]/g,"").length<=2){ dates.push(line); return; }
    // CSV対応：カンマがあればセルごとに見る
    var cells = line.indexOf(",")>=0 ? line.split(",") : [line];
    cells.forEach(function(c){
      c=c.trim(); if(!c) return;
      var mins=parseMinutes(c);
      var tags=extractTags(c);
      var name=memoTaskName(c);
      if(isMeaningful(name)){
        items.push(name);
        if(mins>0) taskMin[name]=(taskMin[name]||0)+mins;
      }
      // タグ別：タグに時間を割り当て（同一セルの重複タグは1回）
      if(mins>0 && tags.length){
        var uniqT={}; tags.forEach(function(t){uniqT[t]=1;});
        Object.keys(uniqT).forEach(function(t){ tagMin[t]=(tagMin[t]||0)+mins; });
      }
    });
  });
  return {taskMin:taskMin, tagMin:tagMin, dates:dates, items:items};
}

