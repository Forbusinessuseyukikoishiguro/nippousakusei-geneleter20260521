  // タスクレコード：1コマ=1行（日付・タスク名・区分・分・コマ）
  var COL=unitColLabel();
  var rec=[[_S("日付"),_S("タスク"),_S("区分"),_S("分"),_S(COL),_S("達成")]];
  var taskAgg={}; // タスク名 -> 合計分
  var dayAgg={};  // 日付 -> 合計分
  days.forEach(function(d){
    (d.periods||[]).forEach(function(p){
      if(p.kind==="break"||p.isBreak) return;
      var rawName=(p.actual||p.plan||"").trim(); if(!rawName) return;
      var name=rawName.replace(/[#＃]\S+/g,"").replace(/\s+/g," ").trim() || rawName; // タグ除去（空になれば元のまま）
      var mins=p.dur||0;
