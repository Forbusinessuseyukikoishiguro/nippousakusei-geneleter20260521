(function init(){
  addTask(); addTask();
  var d=new Date(), w=["日","月","火","水","木","金","土"][d.getDay()];
  var jp=d.getFullYear()+"年"+(d.getMonth()+1)+"月"+d.getDate()+"日("+w+")";
  var slash=d.getFullYear()+"/"+("0"+(d.getMonth()+1)).slice(-2)+"/"+("0"+d.getDate()).slice(-2)+"（"+w+"）";
  document.getElementById("r_date").value=jp;
  document.getElementById("m_date").value=slash;
  document.getElementById("tt_date").value=slash;
  // 丸め設定の初期値を変数に合わせる
  var ru=document.getElementById("round_unit"); if(ru) ru.value=String(ROUND_UNIT);
  var rm=document.getElementById("round_mode"); if(rm) rm.value=ROUND_MODE;
  TT_DEFAULT.forEach(function(p){ addPeriod(p); });
  recalcTT();
  renderQuickTags();
  renderDayList();
  // スキルシート：作業内容を10行seed、文字数カウンタ初期化、保存リスト描画
  for(var si=0; si<10; si++){ skAddWork(); }
  skCount();
  skRenderList();
  // 進捗報告：タスク2行seed
  ciAddTask(); ciAddTask();
  // 自由ひな形：初回は標準テンプレを登録、その後 一覧と差し込み欄を初期化
  tplSeedDefault();
  tplRenderSaved(); tplScan();
  // 月次データ統合：プレビュー初期化
  hubRender();
  // 言語・テーマ初期化（既定は日本語＝オフホワイト＋ペールレッド）
  initLang();
  // 時間割の連携ON/OFF 初期化（既定ON）
  initTtLink();
})();
</script>
