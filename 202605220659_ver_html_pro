function aggregateDays(){
  var days=loadDays();
  var agg={lesson:0,meeting:0,work:0,brk:0}, rateSum=0;
  days.forEach(function(d){
    agg.lesson += (d.kindMin&&d.kindMin.lesson)||0;
    agg.meeting+= (d.kindMin&&d.kindMin.meeting)||0;
    agg.work   += (d.kindMin&&d.kindMin.work)||0;
    agg.brk    += d.breakMin||0;
    rateSum += d.rate||0;
  });
  return {days:days, count:days.length, agg:agg, avgRate: days.length? Math.round(rateSum/days.length):0};
}

