  var km={lesson:0,meeting:0,work:0}, brk=0, custom={}, tagMin={}, planSum=0, actSum=0, rateSum=0;
  var insCount=0, insMin=0;
  days.forEach(function(d){
    km.lesson+=(d.kindMin&&d.kindMin.lesson)||0;
    km.meeting+=(d.kindMin&&d.kindMin.meeting)||0;
