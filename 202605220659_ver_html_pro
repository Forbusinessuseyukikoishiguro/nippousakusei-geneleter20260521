/* 進捗報告（I）：タスク行 */
function ciAddTask(data){
  data=data||{name:"",status:"ontrack",pct:"",note:""};
  var wrap=document.getElementById("cI_taskList");
  var row=document.createElement("div"); row.className="ci-row";
  var name=document.createElement("input"); name.className="ci-name"; name.placeholder="タスク名"; name.value=data.name;
  var st=document.createElement("select"); st.className="ci-status";
  // value属性を固定（英訳してもvalueは不変→ロジックが壊れない）
  [["🟢 順調","ontrack"],["🟡 やや遅延","behind"],["🔴 要対応","attention"],["✅ 完了","done"],["⏸ 未着手","todo"]].forEach(function(s){var o=document.createElement("option");o.textContent=s[0];o.value=s[1];st.appendChild(o);});
  st.value=data.status;
  var pct=document.createElement("input"); pct.className="ci-pct"; pct.placeholder="%"; pct.inputMode="numeric"; pct.value=data.pct;
  var note=document.createElement("input"); note.className="ci-note"; note.placeholder="補足（任意）"; note.value=data.note;
  var del=document.createElement("button"); del.type="button"; del.className="del"; del.textContent="×";
  del.onclick=function(){ row.remove(); };
  // 完了を選んだら%を100に補完
  st.addEventListener("change", function(){ if(st.value==="done" && !pct.value) pct.value="100"; if(st.value==="todo" && !pct.value) pct.value="0"; });
  row.appendChild(name); row.appendChild(st); row.appendChild(pct); row.appendChild(note); row.appendChild(del);
  wrap.appendChild(row);
  i18nRefresh();
}
function ciReadTasks(){
  return [].slice.call(document.querySelectorAll("#cI_taskList .ci-row")).map(function(r){
    var sel=r.querySelector(".ci-status");
    var label=sel.options[sel.selectedIndex] ? sel.options[sel.selectedIndex].textContent : sel.value;
    return {
      name:r.querySelector(".ci-name").value.trim(),
      status:label,            // 表示用（🟢 順調 / 🟢 On track）
      statusKey:sel.value,     // 判定用（ontrack/done/todo…）
      pct:r.querySelector(".ci-pct").value.trim(),
      note:r.querySelector(".ci-note").value.trim()
    };
  }).filter(function(t){return t.name;});
}
// 進捗報告の本文を長さ別に組み立て
function buildProgress(){
  var len=v("cI_len")||"prep";
  var topic=v("cI_topic")||"（案件名）";
  var status=v("cI_status");
  var tasks=ciReadTasks();
  // 全体％：未入力ならタスク％の平均で補完
  var pct=v("cI_pct");
  if(!pct && tasks.length){
    var nums=tasks.map(function(t){return parseInt(t.pct,10);}).filter(function(n){return !isNaN(n);});
    if(nums.length){ pct=String(Math.round(nums.reduce(function(a,b){return a+b;},0)/nums.length)); }
  }
  var pctTxt = pct? (pct+"%") : "";
  var due=v("cI_due");
  var nexts=lines(v("cI_next"));
  var risk=v("cI_risk");
  var head = topic + "：" + status + (pctTxt?(" "+pctTxt):"") + (due?("（期限 "+due+"）"):"");

  var o=[];
  if(len==="1"){
    // 1分：1行結論＋次アクション1つ
    o.push("【進捗1分】"+head);
    if(nexts.length) o.push("次："+nexts[0]);
    if(risk) o.push("⚠ "+risk);
  } else if(len==="3"){
    // 3分：結論＋主要タスク数件＋次アクション
    o.push("【進捗3分】"+head); o.push("");
    if(tasks.length){
      o.push("■タスク");
      tasks.forEach(function(t){ o.push("・"+t.status+" "+t.name+(t.pct?(" "+t.pct+"%"):"")+(t.note?("（"+t.note+"）"):"")); });
      o.push("");
    }
    if(nexts.length){ o.push("■次のアクション"); nexts.forEach(function(x){o.push("・"+x);}); o.push(""); }
    if(risk){ o.push("■リスク・相談"); o.push("・"+risk); }
  } else if(len==="5"){
    // 5分：見出し付きでフル
    o.push("【進捗報告】"+topic); o.push("");
    o.push("■全体ステータス："+status+(pctTxt?(" / "+pctTxt):"")+(due?(" / 期限 "+due):"")); o.push("");
    if(tasks.length){
      o.push("■タスク別の状況");
      tasks.forEach(function(t){ o.push("・"+t.status+" "+t.name+(t.pct?(" "+t.pct+"%"):"")+(t.note?("：" +t.note):"")); });
      o.push("");
    }
    if(nexts.length){ o.push("■次のアクション"); nexts.forEach(function(x){o.push("・"+x);}); o.push(""); }
    if(risk){ o.push("■リスク・困りごと"); o.push("・"+risk); o.push(""); }
    o.push("以上、ご確認よろしくお願いします。");
  } else {
    // PREP：結論→理由→具体例→結論
    o.push("【進捗報告（PREP）】"+topic); o.push("");
    o.push("◆結論（Point）");
    o.push(status+(pctTxt?("、現在 "+pctTxt):"")+"です。"+(due?("期限は "+due+"。"):"")); o.push("");
    o.push("◆理由（Reason）");
    if(risk){ o.push(risk); } else { o.push("予定どおりタスクを消化できているためです。"); } o.push("");
    o.push("◆具体例（Example）");
    if(tasks.length){ tasks.forEach(function(t){ o.push("・"+t.status+" "+t.name+(t.pct?(" "+t.pct+"%"):"")+(t.note?("（"+t.note+"）"):"")); }); }
    else { o.push("（タスク未入力）"); } o.push("");
    o.push("◆まとめ（Point）");
    o.push("引き続き"+(nexts.length?("「"+nexts[0]+"」"):"次のアクション")+"を進めます。"+(nexts.length>1?("ほか："+nexts.slice(1).join("、")):""));
  }
  var txt=o.join("\n");

  // Markdown版
  var m=[];
  var title = (len==="prep") ? "進捗報告（PREP）" : (len==="1"?"進捗（1分）":(len==="3"?"進捗（3分）":(len==="5"?"進捗報告（5分）":"進捗報告")));
  m.push("### "+title+"："+topic);
  m.push("");
  m.push("- **ステータス**："+status+(pctTxt?(" / "+pctTxt):"")+(due?(" / 期限 "+due):""));
  if(tasks.length){
    m.push("");
    m.push("| タスク | 状態 | 進捗 | 補足 |");
    m.push("|---|---|---:|---|");
    tasks.forEach(function(t){ m.push("| "+t.name+" | "+t.status+" | "+(t.pct?t.pct+"%":"")+" | "+(t.note||"")+" |"); });
  }
  if(nexts.length){ m.push(""); m.push("**次のアクション**"); nexts.forEach(function(x){m.push("- "+x);}); }
  if(risk){ m.push(""); m.push("**リスク・相談**：" + risk); }
  var md=m.join("\n");

  return {txt:txt, md:md};
}

