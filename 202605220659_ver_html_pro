function fmtHM(min){
  if(min<=0) return "0:00";
  var h=Math.floor(min/60), m=min%60;
  return h+":"+(m<10?"0":"")+m;
}
// 単位コマ表記（例：1:30（90分／6コマ）。コマ＝現在の丸め単位）
function fmt15(min){
  var u=ROUND_UNIT||15;
  var q=Math.round(min/u);
  return fmtHM(min)+"（"+min+"分／"+q+"コマ）";
}

function addPeriod(data, insertAfterRow){
