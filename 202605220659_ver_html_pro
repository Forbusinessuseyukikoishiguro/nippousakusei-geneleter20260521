// 最後にフォーカスした予定/実績欄にタグを挿入（無ければ最初の予定欄）
function insertTag(t){
  var el=window.__lastTagTarget;
  if(!el || !document.body.contains(el)){
    el=document.querySelector("#ttList .tt-plan");
  }
  if(!el){ toast("挿入先の欄がありません"); return; }
  var tag="#"+t;
  var cur=el.value||"";
  el.value = cur ? (cur.replace(/\s+$/,"")+" "+tag+" ") : (tag+" ");
  el.focus();
  window.__lastTagTarget=el;
  recalcTT();
}

// 予定/実績テキストから #タグ を抽出（#のあと空白・全角空白・改行・カンマ・読点まで）
function extractTags(text){
  if(!text) return [];
  var out=[], re=/[#＃]([^\s,、，\/／]+)/g, m;
  while((m=re.exec(text))!==null){ if(m[1]) out.push(m[1]); }
  return out;
}
// コマ配列から、タグごとの予定時間（分）を積み上げる。タグはplan+actual両方から拾い重複排除
function tagMinutesFromPeriods(periods){
  var tagMin={};
  (periods||[]).forEach(function(p){
    if(p.kind==="break"||p.isBreak) return;
    var dur=p.dur||0; if(!dur) return;
    var tags=extractTags((p.plan||"")+" "+(p.actual||""));
    // 同一コマ内の重複タグは1回に
    var uniqT={}; tags.forEach(function(t){ uniqT[t]=1; });
    Object.keys(uniqT).forEach(function(t){ tagMin[t]=(tagMin[t]||0)+dur; });
  });
  return tagMin;
}

