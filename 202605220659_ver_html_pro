  var plan=document.createElement("input"); plan.className="tt-plan"; plan.placeholder="予定（やること）";
  var act=document.createElement("input"); act.className="tt-actual"; act.placeholder="実績（やったこと）";
  if(data.plan) plan.value=data.plan;
  if(data.actual) act.value=data.actual;
  // タグ挿入先として、最後にフォーカスした欄を記憶
  [plan,act].forEach(function(el){ el.addEventListener("focus", function(){ window.__lastTagTarget=el; }); });
  var stat=document.createElement("select"); stat.className="tt-status";
  ["◎","○","△","—"].forEach(function(s){var o=document.createElement("option");o.textContent=s;stat.appendChild(o);});
  stat.value = data.status || (isBreak ? "—" : "◎");
  // 差込フラグ（チェックボックス）
  var insWrap=document.createElement("label"); insWrap.className="tt-ins"; insWrap.title="差し込み（割込）対応のコマ";
