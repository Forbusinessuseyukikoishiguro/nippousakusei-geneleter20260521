  else { s_tag.push([_S("（タグなし）"),_S(""),_S(""),_S("")]); }

  var buf=_buildXlsx([
    {name:"タスク工数レコード",rows:rec},
    {name:"タスク別月次集計",rows:s_task},
    {name:"日別工数",rows:s_day},
    {name:"タグ別集計",rows:s_tag}
  ]);
