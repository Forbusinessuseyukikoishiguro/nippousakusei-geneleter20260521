function skImportCsv(input){
  var file=input.files&&input.files[0]; if(!file) return;
  var reader=new FileReader();
  reader.onload=function(){
    try{
      var rows=_parseCsv(String(reader.result));
      if(rows.length<2){ toast("データが見つかりません"); return; }
      var h=rows[0].map(function(s){return s.trim();});
      var ix={}; SK_FIELDS.forEach(function(f){ ix[f]=h.indexOf(f); });
      function g(r,f){ return ix[f]>=0 ? (r[ix[f]]||"") : ""; }
      var imported=rows.slice(1).map(function(r){
        var rec={
          no:g(r,"No"),industry:g(r,"業種"),role:g(r,"役割"),period:g(r,"期間"),scale:g(r,"規模"),
          lang:g(r,"言語ツール"),db:g(r,"DB"),os:g(r,"サーバOS"),mw:g(r,"環境MW"),phase:g(r,"担当工程"),
          title:g(r,"企業PJ名"),sys:g(r,"システム内容"),proc:g(r,"対応工程"),duty:g(r,"担当業務"),
          work:lines(g(r,"作業内容")), out:g(r,"成果物")
        };
        rec._key=rec.no||rec.title||("案件");
        return rec;
      }).filter(function(rec){ return rec.title||rec.sys||rec.work.length; });
      // 既存とマージ（_keyで上書き）
      var map={}; skLoad().forEach(function(x){ map[x._key]=x; });
      imported.forEach(function(x){ map[x._key]=x; });
      var merged=Object.keys(map).map(function(k){return map[k];});
      skStore(merged); skRenderList();
      if(merged.length){ skLoadToForm(merged[merged.length-1]._key); }
      toast(imported.length+"件を取り込みました");
    }catch(e){ toast("読み込みに失敗しました"); }
    input.value="";
  };
  reader.readAsText(file,"UTF-8");
}

/* ---- output ---- */
function setOut(text, md){
  lastOut.txt = text;
  lastOut.md  = (typeof md==="string" && md.length) ? md : text;
  document.getElementById("output").value=text;
  var ow=document.querySelector(".outwrap");
  if(ow && ow.scrollIntoView){ ow.scrollIntoView({behavior:"smooth",block:"start"}); }
}
function toast(msg){
  var t=document.getElementById("toast"); t.textContent=msg; t.classList.add("show");
  setTimeout(function(){ t.classList.remove("show"); },1600);
}
function copyOut(){
  var text=document.getElementById("output").value;
  if(!text){ toast("先に生成してください"); return; }
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(function(){toast("コピーしました");},function(){fallbackCopy(text);});
  } else { fallbackCopy(text); }
}
function fallbackCopy(text){
  var ta=document.getElementById("output"); ta.select();
  try{ document.execCommand("copy"); toast("コピーしました"); }catch(e){ toast("コピーできませんでした"); }
}
function downloadOut(fmt){
  fmt = (fmt==="md") ? "md" : "txt";
  var text = (fmt==="md") ? lastOut.md : lastOut.txt;
  if(!text){ text=document.getElementById("output").value; } // 念のためのフォールバック
  if(!text){ toast("先に生成してください"); return; }
  var names={report:"日報",memo:"メモ日報",chat:"相談テンプレ",timetable:"時間割HR",skill:"スキルシート",pdca:"一人MTG_PDCA",mtg2:"一人MTG2_目標KPT",tpl:"ひな形日報"};
  var mime=(fmt==="md") ? "text/markdown;charset=utf-8" : "text/plain;charset=utf-8";
  var blob=new Blob(["\uFEFF"+text],{type:mime});
  var a=document.createElement("a");
  a.href=URL.createObjectURL(blob);
  a.download=(names[currentTab]||"出力")+"_"+today()+"."+fmt;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(a.href);
  toast((fmt==="md"?"マークダウン":"テキスト")+"を保存しました");
}

