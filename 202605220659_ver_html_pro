/* ---- TAB2 build: メモ版 ---- */
function memoSection(title, pairs){
  // pairs: [labelOrNull, lines[]] ; lines already prefixed
  var has=pairs.some(function(p){return p[1] && p[1].length;});
  if(!has) return "";
  var s=[BAR, title, BAR];
  pairs.forEach(function(p){
    if(!(p[1] && p[1].length)) return;
    if(p[0]) s.push("▼ "+p[0]);
    s.push(p[1].join("\n"));
    s.push("");
  });
  return s.join("\n").replace(/\n+$/,"")+"\n";
}
function chk(id){ return linesOf(id).map(function(s){return "[ ] "+s;}); }
function dot(id){ return linesOf(id).map(function(s){return "・"+s;}); }
// Markdown用：チェックリスト項目 / 箇条書き項目
function chkMd(id){ return linesOf(id).map(function(s){return "- [ ] "+s;}); }
function dotMd(id){ return linesOf(id).map(function(s){return "- "+s;}); }

// Markdown版セクション：見出し＋小見出し＋本文
function memoSectionMd(title, pairs){
  var has=pairs.some(function(p){return p[1] && p[1].length;});
  if(!has) return "";
  var s=["## "+title, ""];
  pairs.forEach(function(p){
    if(!(p[1] && p[1].length)) return;
    if(p[0]) s.push("### "+p[0]);
    s.push(p[1].join("\n"));
    s.push("");
  });
  return s.join("\n").replace(/\n+$/,"")+"\n";
}

